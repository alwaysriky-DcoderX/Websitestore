<div class="mx-auto max-w-lg px-4 py-16 text-center" data-aos="zoom-in">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-[2rem] bg-gradient-to-tr from-blue-500/10 to-indigo-500/10 border border-blue-500/20 text-blue-600 dark:text-blue-400 mb-6 relative">
