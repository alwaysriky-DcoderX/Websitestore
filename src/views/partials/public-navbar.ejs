<%# public-navbar.ejs — Desktop: top glass nav | Mobile: compact bar + bottom sheet drawer %>
<nav x-data="{ drawerOpen: false, currentPath: window.location.pathname }" class="bg-white/90 dark:bg-[#0D0D14]/90 backdrop-blur-2xl border-b border-slate-200/60 dark:border-white/5 sticky top-0 z-50">

    <%# ===================== TOP BAR (Mobile + Desktop) ===================== %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 sm:h-[4.5rem]">

            <%# Brand %>
            <a href="/" class="flex items-center gap-2.5 shrink-0">
                <img src="<%= settings.web_logo %>" alt="<%= settings.web_name %>" class="w-8 h-8 sm:w-9 sm:h-9 object-contain rounded-xl shadow-md shrink-0">
                <span class="text-[15px] sm:text-lg font-black tracking-tight text-slate-900 dark:text-white whitespace-nowrap">
                    <%= settings.web_name %>
                </span>
            </a>

            <%# Desktop Links — hidden on mobile %>
            <div class="hidden md:flex items-center gap-1">
                <a href="/" :class="currentPath === '/' ? 'bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-white/5 hover:text-slate-900 dark:hover:text-white'" class="px-4 py-2 rounded-xl text-sm font-semibold transition-all"><%= t('nav_home') %></a>

                <a href="/docs" :class="currentPath.startsWith('/docs') ? 'bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-white/5 hover:text-slate-900 dark:hover:text-white'" class="px-4 py-2 rounded-xl text-sm font-semibold transition-all"><%= t('nav_docs') %></a>
            </div>

            <%# Desktop Actions — hidden on mobile %>
            <div class="hidden md:flex items-center gap-2">
                <%# Language Selector %>
                <div class="relative" x-data="{ langOpen: false }">
                    <button @click="langOpen = !langOpen" @keydown.escape="langOpen = false" class="flex items-center gap-1.5 px-3 py-2 rounded-xl text-xs font-bold text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-white/5 transition-all">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
                        <%= i18n.language.toUpperCase() %>
                    </button>
                    <div x-show="langOpen" @click.away="langOpen = false" x-transition:enter="transition ease-out duration-150" x-transition:enter-start="opacity-0 scale-95 -translate-y-1" x-transition:enter-end="opacity-100 scale-100 translate-y-0" class="absolute right-0 top-full mt-1.5 w-36 bg-white dark:bg-[#1A1A28] border border-slate-200 dark:border-white/10 rounded-2xl shadow-xl z-[70] overflow-hidden" x-cloak>
                        <button @click="uiCore.changeLanguage('id'); langOpen=false" class="w-full text-left px-4 py-2.5 text-xs font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-white/5 flex items-center gap-2">🇮🇩 Indonesia</button>
                        <button @click="uiCore.changeLanguage('en'); langOpen=false" class="w-full text-left px-4 py-2.5 text-xs font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-white/5 flex items-center gap-2">🇺🇸 English</button>
                        <button @click="uiCore.changeLanguage('ms'); langOpen=false" class="w-full text-left px-4 py-2.5 text-xs font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-white/5 flex items-center gap-2">🇲🇾 Melayu</button>
                    </div>
                </div>

                <%# Theme Toggle %>
                <button onclick="uiCore.toggleTheme()" class="w-9 h-9 rounded-xl flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-white/5 transition-all" title="Toggle theme">
                    <svg class="w-4.5 h-4.5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    <svg class="w-4.5 h-4.5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                </button>

                <%# Auth %>
                <div class="flex items-center gap-2 ml-1 pl-3 border-l border-slate-200 dark:border-white/10">
                    <% if (user) { %>
                        <a href="/dashboard" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl transition-all hover:shadow-lg hover:shadow-blue-600/30"><%= t('nav_dashboard') %></a>
                    <% } else { %>
                        <a href="/auth/login" class="px-4 py-2 text-sm font-semibold text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors"><%= t('nav_login') %></a>
                        <a href="/auth/register" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl transition-all hover:shadow-lg hover:shadow-blue-600/30"><%= t('nav_register') %></a>
                    <% } %>
                </div>
            </div>

            <%# Mobile Right Side — icons + hamburger %>
            <div class="flex md:hidden items-center gap-1.5">
                <button onclick="uiCore.toggleTheme()" class="w-9 h-9 rounded-xl flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-white/5 transition-all">
                    <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                </button>
                <% if (!user) { %>
                    <a href="/auth/register" class="px-3.5 py-2 bg-blue-600 text-white text-xs font-bold rounded-xl">Mulai</a>
                <% } else { %>
                    <a href="/dashboard" class="px-3.5 py-2 bg-blue-600 text-white text-xs font-bold rounded-xl">Dashboard</a>
                <% } %>
                <button @click="drawerOpen = true" class="w-9 h-9 rounded-xl flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-white/5 transition-all" aria-label="Buka Menu">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
            </div>
        </div>
    </div>

    <%# ===================== MOBILE BOTTOM SHEET DRAWER ===================== %>
    <%# Backdrop %>
    <div x-show="drawerOpen"
         @click="drawerOpen = false"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="md:hidden fixed inset-0 bg-black/40 backdrop-blur-sm z-[80]"
         x-cloak>
    </div>

    <%# Bottom Sheet %>
    <div x-show="drawerOpen"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-8"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 translate-y-8"
         class="md:hidden fixed bottom-0 left-0 right-0 z-[90] bg-white dark:bg-[#13131F] rounded-t-[2rem] shadow-2xl border-t border-slate-200 dark:border-white/10 pb-safe"
         x-cloak>

        <%# Drag Handle %>
        <div class="flex justify-center pt-4 pb-2">
            <div class="w-10 h-1 bg-slate-300 dark:bg-slate-600 rounded-full"></div>
        </div>

        <%# Sheet Header %>
        <div class="flex items-center justify-between px-6 pt-2 pb-4 border-b border-slate-100 dark:border-white/5">
            <span class="text-sm font-bold text-slate-900 dark:text-white">Menu</span>
            <button @click="drawerOpen = false" class="w-8 h-8 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center text-slate-500 dark:text-slate-400 transition-all active:scale-95">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <%# Nav Links %>
        <nav class="px-4 pt-3 pb-2 space-y-1">
            <a href="/" @click="drawerOpen = false" class="flex items-center gap-3.5 px-4 py-3.5 rounded-2xl transition-all active:scale-[.98]" :class="currentPath === '/' ? 'bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400' : 'text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-white/5'">
                <div class="w-9 h-9 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center shrink-0">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                </div>
                <span class="font-semibold text-sm">Home</span>
            </a>

            <a href="/docs" @click="drawerOpen = false" class="flex items-center gap-3.5 px-4 py-3.5 rounded-2xl transition-all active:scale-[.98]" :class="currentPath.startsWith('/docs') ? 'bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400' : 'text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-white/5'">
                <div class="w-9 h-9 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center shrink-0">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <span class="font-semibold text-sm"><%= t('docs') %></span>
            </a>
        </nav>

        <%# Language row %>
        <div class="px-6 py-3 border-t border-slate-100 dark:border-white/5">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2.5">Bahasa</p>
            <div class="flex gap-2">
                <button onclick="uiCore.changeLanguage('id')" class="flex-1 py-2.5 rounded-xl text-xs font-bold border transition-all active:scale-95 <%= i18n.language === 'id' ? 'bg-blue-600 border-blue-600 text-white' : 'bg-slate-50 dark:bg-white/5 border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-400' %>">🇮🇩 ID</button>
                <button onclick="uiCore.changeLanguage('en')" class="flex-1 py-2.5 rounded-xl text-xs font-bold border transition-all active:scale-95 <%= i18n.language === 'en' ? 'bg-blue-600 border-blue-600 text-white' : 'bg-slate-50 dark:bg-white/5 border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-400' %>">🇺🇸 EN</button>
                <button onclick="uiCore.changeLanguage('ms')" class="flex-1 py-2.5 rounded-xl text-xs font-bold border transition-all active:scale-95 <%= i18n.language === 'ms' ? 'bg-blue-600 border-blue-600 text-white' : 'bg-slate-50 dark:bg-white/5 border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-400' %>">🇲🇾 MY</button>
            </div>
        </div>

        <% if (!user) { %>
        <%# Auth buttons at bottom of sheet %>
        <div class="px-4 pb-6 pt-3 flex gap-3">
            <a href="/auth/login" class="flex-1 py-3.5 text-center text-sm font-bold text-slate-700 dark:text-slate-300 bg-slate-100 dark:bg-white/5 rounded-2xl transition-all active:scale-[.98]"><%= t('nav_login') %></a>
            <a href="/auth/register" class="flex-1 py-3.5 text-center text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-2xl shadow-lg shadow-blue-600/30 transition-all active:scale-[.98]"><%= t('nav_register') %></a>
        </div>
        <% } else { %>
        <div class="px-4 pb-6 pt-3">
            <a href="/dashboard" class="w-full block py-3.5 text-center text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-2xl shadow-lg shadow-blue-600/30 transition-all active:scale-[.98]">Ke Dashboard</a>
        </div>
        <% } %>
    </div>
</nav>
