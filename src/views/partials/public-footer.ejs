<!-- Footer Section -->
<footer class="relative z-10 w-full bg-white dark:bg-[#0B0E1A] border-t border-slate-200 dark:border-slate-800 pt-16 pb-8">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
            
            <!-- Brand -->
            <div class="md:col-span-2 space-y-6">
                <a href="/" class="flex items-center gap-3 group w-max">
                    <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-purple-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/20 group-hover:scale-105 transition-all">
                        <img src="<%= settings && settings.web_logo ? settings.web_logo : '/img/logo.png' %>" alt="Logo" class="w-6 h-6 object-contain filter brightness-0 invert">
                    </div>
                    <span class="text-xl font-black bg-gradient-to-r from-slate-900 to-slate-700 dark:from-white dark:to-slate-300 bg-clip-text text-transparent group-hover:from-blue-600 group-hover:to-purple-600 transition-all">
                        <%= settings && settings.web_name ? settings.web_name : 'Auto Order' %>
                    </span>
                </a>
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400 leading-relaxed max-w-sm">
                    <%= settings && settings.web_description ? settings.web_description : 'Platform penyedia layanan digital dan hosting Pterodactyl terbaik.' %>
                </p>
                <!-- Social Links -->
                <div class="flex items-center gap-4">
                    <a href="#" class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-blue-600 hover:text-white transition-all hover:scale-110 shadow-lg hover:shadow-blue-500/25">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
                    </a>
                    <a href="#" class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-indigo-600 hover:text-white transition-all hover:scale-110 shadow-lg hover:shadow-indigo-500/25">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    </a>
                </div>
            </div>

            <div class="md:col-span-1">
                <h4 class="text-slate-900 dark:text-white font-bold mb-6 relative inline-block">
                    Dukungan
                    <div class="absolute -bottom-2 left-0 w-1/2 h-0.5 bg-purple-500 rounded-full"></div>
                </h4>
                <ul class="space-y-4">
                    <li><a href="/dashboard/support" class="text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Pusat Bantuan</a></li>
                    <li><a href="/terms" class="text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Syarat & Ketentuan</a></li>
                    <li><a href="/terms" class="text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Kebijakan Privasi</a></li>
                </ul>
            </div>

            <!-- Connect -->
            <div class="md:col-span-1">
                <h4 class="text-slate-900 dark:text-white font-bold mb-6 relative inline-block">
                    Pembayaran
                    <div class="absolute -bottom-2 left-0 w-1/2 h-0.5 bg-emerald-500 rounded-full"></div>
                </h4>
                <div class="flex flex-wrap gap-3">
                    <div class="px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-xs font-bold text-slate-600 dark:text-slate-400">QRIS</div>
                    <div class="px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-xs font-bold text-slate-600 dark:text-slate-400">DANA</div>
                    <div class="px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-xs font-bold text-slate-600 dark:text-slate-400">GoPay</div>
                    <div class="px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-xs font-bold text-slate-600 dark:text-slate-400">OVO</div>
                    <div class="px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-xs font-bold text-slate-600 dark:text-slate-400">LinkAja</div>
                    <div class="px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-xs font-bold text-slate-600 dark:text-slate-400">Bank Transfer</div>
                </div>
            </div>
            
        </div>

        <div class="pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-col md:flex-row items-center justify-between gap-4">
            <p class="text-sm font-medium text-slate-500 dark:text-slate-500">
                &copy; <%= new Date().getFullYear() %> <%= settings && settings.web_name ? settings.web_name : 'Auto Order' %>. All rights reserved.
            </p>
            <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                <span class="text-xs font-bold text-slate-500 dark:text-slate-400">Sistem Berjalan Normal</span>
            </div>
        </div>
    </div>
</footer>
