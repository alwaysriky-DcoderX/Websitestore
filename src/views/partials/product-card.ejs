<% 
    const type = product.category ? product.category.type : 'other';
    const name = product.name.toLowerCase();
    
    // Smart Icon Logic
    const getIcon = (p) => {
        if (p.image && p.image !== '/img/default-product.png') return `<img src="${p.image}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">`;
        if (p.iconSVG) return `<div class="w-full h-full flex items-center justify-center p-8 group-hover:scale-110 transition-transform duration-500">${p.iconSVG}</div>`;
        
        // Nokos / OTP Icons
        if (p.otpServiceId || type === 'otp') {
            if (name.includes('whatsapp')) return `<div class="w-full h-full bg-emerald-500/10 flex items-center justify-center text-emerald-500 group-hover:scale-110 transition-transform duration-500"><svg class="w-16 h-16 drop-shadow-[0_0_15px_rgba(16,185,129,0.3)]" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.5-5.739-1.446L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.864-9.858.002-2.634-1.02-5.11-2.881-6.974-1.86-1.863-4.334-2.887-6.97-2.889-5.442 0-9.87 4.42-9.874 9.86-.001 1.748.46 3.453 1.337 4.97l-.994 3.63 3.733-.979zm11.233-6.843c-.3-.15-1.771-.875-2.046-.975-.276-.1-.477-.15-.677.15-.199.3-.777.975-.951 1.175-.174.2-.349.225-.648.075-.3-.15-1.266-.467-2.41-1.485-.89-.793-1.49-1.773-1.665-2.073-.174-.3-.019-.462.13-.611.135-.134.3-.349.449-.524.149-.175.199-.3.299-.5.1-.2.05-.375-.025-.525-.075-.15-.677-1.625-.926-2.225-.244-.589-.492-.51-.677-.52-.175-.008-.375-.01-.575-.01-.2 0-.525.075-.8.375-.276.3-1.05 1.025-1.05 2.5s1.075 2.9 1.225 3.1c.15.2 2.11 3.224 5.11 4.526.714.31 1.272.495 1.707.634.717.228 1.368.196 1.884.119.574-.085 1.771-.725 2.022-1.425.25-.7.25-1.3.175-1.425-.075-.125-.275-.2-.575-.35z"/></svg></div>`;
            if (name.includes('telegram')) return `<div class="w-full h-full bg-sky-500/10 flex items-center justify-center text-sky-500 group-hover:scale-110 transition-transform duration-500"><svg class="w-16 h-16 drop-shadow-[0_0_15px_rgba(14,165,233,0.3)]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm5.56 8.18l-1.91 9.02c-.14.64-.52.8-.1.8l-2.91-2.15-1.4 1.35c-.15.15-.28.27-.58.27l.2-2.94 5.35-4.83c.23-.2-.05-.32-.36-.12L9.13 13.22l-2.85-.89c-.62-.19-.63-.62.13-.92l11.13-4.3c.51-.19.96.11.75.92-.01-.01-.01-.01-.01-.01z"/></svg></div>`;
            if (name.includes('google')) return `<div class="w-full h-full bg-red-500/10 flex items-center justify-center text-red-500 group-hover:scale-110 transition-transform duration-500"><svg class="w-16 h-16 drop-shadow-[0_0_15px_rgba(239,68,68,0.3)]" viewBox="0 0 24 24" fill="currentColor"><path d="M12.24 10.285V14.4h6.887c-.648 2.41-2.519 4.114-6.887 4.114-4.664 0-8.443-3.778-8.443-8.443s3.778-8.443 8.443-8.443c2.25 0 4.3.878 5.83 2.301l3.18-3.18C18.622 1.05 15.63 0 12.24 0 5.48 0 0 5.48 0 12.24s5.48 12.24 12.24 12.24c6.8 0 12.24-5.44 12.24-12.24 0-.82-.08-1.63-.22-2.41h-12.02z"/></svg></div>`;
            return `<div class="w-full h-full bg-purple-500/10 flex items-center justify-center text-purple-600 group-hover:scale-110 transition-transform duration-500"><svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg></div>`;
        }

        // Pterodactyl Icons
        if (type === 'pterodactyl') {
            if (name.includes('node')) return `<div class="w-full h-full bg-emerald-500/10 flex items-center justify-center"><svg class="w-16 h-16 text-emerald-600" viewBox="0 0 24 24" fill="currentColor"><path d="M11.992 0L3.5 4.904v9.808L11.992 19.62l8.508-4.908V4.904L11.992 0zm-1.076 13.924c0 .324-.04.61-.122.856-.08.246-.192.443-.334.59-.142.147-.31.25-.504.31-.194.06-.398.09-.614.09-.328 0-.616-.07-.866-.214-.25-.143-.45-.333-.594-.572-.145-.238-.225-.506-.238-.8h1.22c.008.135.034.254.076.354.043.1.106.182.19.245.084.062.19.094.318.094.135 0 .24-.025.317-.074.077-.048.134-.112.167-.19.034-.078.05-.164.05-.258 0-.084-.016-.16-.048-.226-.03-.067-.08-.13-.153-.19s-.167-.116-.282-.17c-.115-.054-.257-.112-.424-.175a4.01 4.01 0 01-.65-.3c-.2-.116-.363-.264-.49-.444-.127-.18-.19-.413-.19-.698 0-.294.043-.548.13-.762.085-.213.208-.387.365-.522.158-.135.344-.233.558-.292.214-.06.444-.09.688-.09.283 0 .54.058.768.172.228.115.412.274.552.476.14.202.223.44.248.71h-1.21a.75.75 0 00-.174-.356.452.452 0 00-.312-.136.425.425 0 00-.3.1c-.078.067-.117.158-.117.274 0 .093.018.172.054.238.036.066.088.12.155.163.067.043.144.08.232.112s.178.06.27.087l.21.06c.19.055.377.126.563.214.186.088.345.21.478.363.133.153.232.344.298.572.066.228.1.494.1.798z"/></svg></div>`;
            if (name.includes('python')) return `<div class="w-full h-full bg-blue-500/10 flex items-center justify-center"><svg class="w-16 h-16 text-blue-600" viewBox="0 0 24 24" fill="currentColor"><path d="M14.25.18l.9.2.73.26.59.3.45.35.32.4.23.43.15.45.08.47.04.48v1.65H15V2.33c0-.13-.03-.25-.08-.36-.05-.11-.13-.2-.23-.28-.1-.08-.22-.14-.35-.17a1.05 1.05 0 00-.47 0c-.13.03-.25.09-.35.17s-.18.17-.23.28c-.05.11-.08.23-.08.36v3.31c0 .13.03.26.08.37.05.11.13.21.23.29.1.08.22.14.35.17.13.03.26.04.4.03h3.53l.4-.03.35-.07.3-.12.23-.17.16-.21.1-.25.03-.3v-3.53l-.03-.3-.07-.25-.12-.22-.17-.18-.21-.13-.25-.09-.3-.04h-4.3l-.2-.05z"/></svg></div>`;
            if (name.includes('linux') || name.includes('vps')) return `<div class="w-full h-full bg-slate-500/10 flex items-center justify-center"><svg class="w-16 h-16 text-slate-700 dark:text-slate-300" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c-.5 0-1 .5-1.5 1.5S10 7 10 7c-.5.5-1 1-1 1.5s.5 1 1 1.5c.5.5 1 1 1.5 1s1-.5 1.5-1c.5-.5 1-1 1-1.5s-.5-1-1-1.5-1-.5-1-.5.5-1.5 0-3.5z"/></svg></div>`;
            return `<div class="w-full h-full bg-blue-600/10 flex items-center justify-center text-blue-600"><svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path></svg></div>`;
        }
        
        // Script Icons (EJS/Code)
        if (type === 'script') {
            return `<div class="w-full h-full bg-amber-500/5 dark:bg-amber-500/10 flex items-center justify-center text-amber-600 group-hover:bg-amber-500/20 transition-colors"><svg class="w-16 h-16 drop-shadow-[0_0_15px_rgba(245,158,11,0.2)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg></div>`;
        }

        // Premium App Icons
        if (type === 'premium_app') {
            if (name.includes('netflix')) return `<div class="w-full h-full bg-red-600/10 flex items-center justify-center text-red-600"><span class="text-6xl font-black italic">N</span></div>`;
            if (name.includes('spotify')) return `<div class="w-full h-full bg-emerald-500/10 flex items-center justify-center text-emerald-600 drop-shadow-[0_0_15px_rgba(16,185,129,0.3)]"><svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.54.659.3 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.24 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.781s.18-1.2.78-1.381c4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.54-1.019.72-1.619.42z"/></svg></div>`;
            if (name.includes('youtube')) return `<div class="w-full h-full bg-red-600/10 flex items-center justify-center text-red-600 drop-shadow-[0_0_15px_rgba(220,38,38,0.3)]"><svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24"><path d="M21.582 6.186a2.78 2.78 0 00-1.956-1.959C17.9 3.8 12 3.8 12 3.8s-5.9 0-7.626.427A2.78 2.78 0 002.418 6.186C2 7.914 2 12 2 12s0 4.086.418 5.814a2.78 2.78 0 001.956 1.959C6.1 20.2 12 20.2 12 20.2s5.9 0 7.626-.427a2.78 2.78 0 001.956-1.959C22 16.086 22 12 22 12s0-4.086-.418-5.814zM9.99 15.46V8.54l6.502 3.46-6.502 3.46z"/></svg></div>`;
            return `<div class="w-full h-full bg-indigo-500/10 flex items-center justify-center text-indigo-600 drop-shadow-[0_0_15px_rgba(99,102,241,0.3)]"><svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg></div>`;
        }

        return `<div class="w-full h-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400 dark:text-slate-500"><svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg></div>`;
    }
%>
<div class="group <%= type === 'script' ? 'bg-slate-50 dark:bg-[#090b10] border-slate-200 dark:border-slate-800' : (type === 'premium_app' ? 'bg-gradient-to-b from-white to-slate-50 dark:from-[#13141F] dark:to-[#0A0B10] border-slate-200 dark:border-white/5' : 'bg-white dark:bg-[#12121A] border-slate-200 dark:border-slate-800') %> rounded-[2rem] border shadow-sm hover:shadow-2xl hover:shadow-blue-600/10 transition-all duration-500 hover:-translate-y-2 overflow-hidden flex flex-col h-full relative" data-aos="fade-up">
    
    <!-- Top Right Badges -->
    <div class="absolute top-4 right-4 z-20 flex flex-col gap-2 items-end">
        <% if (type === 'premium_app') { %>
            <% if (product.price > 15000) { %>
                <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest bg-gradient-to-r from-amber-400 to-orange-500 text-white shadow-lg shadow-orange-500/20">🔥 Best Seller</span>
            <% } else { %>
                <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest bg-gradient-to-r from-blue-400 to-indigo-500 text-white shadow-lg shadow-blue-500/20">✨ Popular</span>
            <% } %>
            <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest <%= (product.stock > 0) ? 'bg-emerald-500/90 backdrop-blur text-white' : 'bg-red-500 text-white' %> shadow-lg">
                <%= (product.stock > 0) ? product.stock + ' IN STOCK' : 'SOLD OUT' %>
            </span>
        <% } %>
        
        <% if (type === 'script') { %>
            <span class="px-3 py-1 rounded-lg text-[9px] font-mono font-bold uppercase tracking-widest bg-blue-100 dark:bg-blue-500/20 text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-500/30">
                v1.0.0
            </span>
        <% } %>
    </div>

    <!-- Product Image / Icon -->
    <div class="relative h-52 overflow-hidden shrink-0 <%= type === 'script' ? 'border-b border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-[#0A0C14]' : '' %>">
        <%- getIcon(product) %>
        
        <% if (type === 'script') { %>
            <div class="absolute top-0 left-0 right-0 h-8 bg-slate-200/80 dark:bg-slate-900/80 backdrop-blur-md flex items-center px-4 gap-2 border-b border-slate-300 dark:border-slate-800">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-amber-500"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
                <span class="text-[9px] font-mono text-slate-500 ml-2">~/source/<%= name.replace(/\s+/g, '-') %>.sh</span>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-slate-50 dark:from-[#0f111a] via-transparent to-transparent z-10"></div>
        <% } else { %>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <% } %>
        
        <!-- Category Badge -->
        <div class="absolute top-4 left-4 z-20 <%= type === 'script' ? 'top-12' : '' %>">
            <span class="px-3 py-1.5 <%= type === 'script' ? 'bg-amber-100/80 dark:bg-slate-800/80 text-amber-600 dark:text-amber-400 font-mono border-amber-200 dark:border-slate-700' : 'bg-white/90 dark:bg-slate-900/90 text-blue-600 dark:text-blue-400 border-white/20 dark:border-slate-700' %> backdrop-blur-md rounded-xl text-[9px] font-black uppercase tracking-widest shadow-sm border">
                <%= product.category ? product.category.name : 'Uncategorized' %>
            </span>
        </div>
        
        <% const userLoggedIn = typeof user !== 'undefined' && user; %>
        <% if ((product.otpServiceId || type === 'smm') && !userLoggedIn) { %>
            <div class="absolute top-4 right-4 z-20">
                <span class="px-3 py-1.5 bg-amber-500 text-white rounded-xl text-[9px] font-black uppercase tracking-widest shadow-lg animate-pulse">
                    Login Required
                </span>
            </div>
        <% } %>

        <!-- Quick View Price (Overlay) -->
        <div class="absolute bottom-4 left-4 right-4 z-20 translate-y-10 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
            <p class="text-[10px] font-black text-slate-700 dark:text-white/60 uppercase tracking-widest mb-0.5"><%= type === 'premium_app' ? 'Langganan' : (type === 'script' ? 'Lisensi Lifetime' : 'Mulai Dari') %></p>
            <p class="text-xl font-black text-slate-900 dark:text-white">Rp <%= product.price.toLocaleString('id-ID') %></p>
        </div>
    </div>

    <!-- Product Info -->
    <div class="p-5 sm:p-6 flex-1 flex flex-col relative z-20">
        <% if (product.pteroNode) { %>
            <div class="flex items-center gap-1.5 mb-2 flex-wrap">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-blue-50 dark:bg-blue-950/40 text-blue-600 dark:text-blue-400 rounded-lg text-[9px] font-black uppercase tracking-widest border border-blue-100/50 dark:border-blue-900/30">
                    <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                    <%= product.pteroNode.name %>
                </span>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-lg text-[9px] font-black uppercase tracking-widest border border-slate-200/50 dark:border-slate-700/50">
                    <%= product.pteroNode.location || 'ID' %>
                </span>
            </div>
        <% } %>

        <h3 class="text-lg font-black mb-2 leading-tight transition-colors <%= type === 'script' ? 'text-slate-900 dark:text-white font-mono group-hover:text-amber-500 dark:group-hover:text-amber-400' : 'text-slate-900 dark:text-white group-hover:text-blue-600' %>">
            <%= type === 'script' ? '> ' : '' %><%= product.name %>
        </h3>
        
        <% if (product.category && product.category.type === 'pterodactyl' && (product.pteroMemory || product.pteroDisk || product.pteroCpu)) { %>
            <!-- Server Specs -->
            <div class="grid grid-cols-3 gap-2 mb-4 p-3 bg-slate-50 dark:bg-slate-900/60 rounded-xl border border-slate-100 dark:border-slate-800">
                <% if (product.pteroMemory) { %>
                <div class="text-center">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-0.5">RAM</p>
                    <p class="text-sm font-black text-blue-600 dark:text-blue-400"><%= formatPteroSize(product.pteroMemory) %></p>
                </div>
                <% } %>
                <% if (product.pteroDisk) { %>
                <div class="text-center border-x border-slate-200 dark:border-slate-700/50">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-0.5">Disk</p>
                    <p class="text-sm font-black text-emerald-600 dark:text-emerald-400"><%= formatPteroSize(product.pteroDisk) %></p>
                </div>
                <% } %>
                <% if (product.pteroCpu) { %>
                <div class="text-center">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-0.5">CPU</p>
                    <p class="text-sm font-black text-purple-600 dark:text-purple-400"><%= product.pteroCpu %>%</p>
                </div>
                <% } %>
            </div>
        <% } %>

        <p class="text-xs font-medium line-clamp-2 mb-4 flex-1 leading-relaxed <%= type === 'script' ? 'text-slate-500 dark:text-slate-400 font-mono' : 'text-slate-500 dark:text-slate-400' %>">
            <%= product.description %>
        </p>
        
        <div class="flex items-center justify-between pt-5 border-t <%= type === 'script' ? 'border-slate-200 dark:border-slate-800/80' : 'border-slate-100 dark:border-slate-800' %>">
            <div class="group-hover:hidden transition-all">
                <p class="text-[10px] font-black uppercase tracking-widest mb-0.5 <%= type === 'script' ? 'text-slate-500 dark:text-slate-400' : 'text-slate-400 dark:text-slate-500' %>"><%= type === 'premium_app' ? 'Harga / Bulan' : 'Price' %></p>
                <p class="text-lg font-black transition-all <%= type === 'script' ? 'text-amber-600 dark:text-amber-400 font-mono' : 'text-slate-900 dark:text-white' %>">Rp <%= product.price.toLocaleString('id-ID') %></p>
            </div>
            
            <!-- Buy Button -->
            <% 
                let checkoutUrl = '';
                if (product.otpServiceId) {
                    checkoutUrl = isDashboard ? '/nokos/checkout/' + product.id : '/product/' + product.id;
                } else {
                    checkoutUrl = isDashboard ? '/dashboard/checkout/' + product.id : '/product/' + product.id;
                }
            %>
            <% if ((product.otpServiceId || type === 'smm') && !userLoggedIn && !isDashboard) { %>
                     <a href="#" onclick="event.preventDefault(); window.uiCore.showLoginToast('Maaf, produk ini hanya tersedia untuk pengguna yang sudah login. Silakan login terlebih dahulu agar sistem dapat memprosesnya.', '/auth/login');" 
                   class="flex-1 group-hover:w-full bg-amber-500 hover:bg-amber-600 text-white py-3.5 px-6 rounded-2xl font-black text-xs flex items-center justify-center gap-2 transition-all duration-300 shadow-xl shadow-amber-500/10 hover:shadow-amber-500/30">
                    <span>Login Required</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h3a3 3 0 013 3v1"></path></svg>
                </a>
            <% } else if (product.otpServiceId && userLoggedIn && !isDashboard) { %>
                <a href="/dashboard/marketplace" 
                   class="flex-1 group-hover:w-full bg-blue-600 hover:bg-blue-500 text-white py-3.5 px-6 rounded-2xl font-black text-xs flex items-center justify-center gap-2 transition-all duration-300 shadow-xl shadow-blue-600/10 hover:shadow-blue-600/30">
                    <span>Go to Marketplace</span>
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                </a>
            <% } else if (product.otpServiceId && isDashboard) { %>
                <button @click.prevent="selectNokosProduct({ id: '<%= product.id %>', name: '<%= product.name %>' })"
                   class="flex-1 group-hover:w-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 py-3.5 px-6 rounded-2xl font-black text-xs flex items-center justify-center gap-2 hover:bg-blue-600 dark:hover:bg-blue-600 hover:text-white transition-all duration-300 shadow-xl shadow-black/5 hover:shadow-blue-600/20">
                    <span>Beli Sekarang</span>
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                </button>
            <% } else { %>
                <a href="<%= checkoutUrl %>" 
                   class="flex-1 group-hover:w-full <%= type === 'script' ? 'bg-amber-500 text-slate-900 hover:bg-amber-400 font-mono' : 'bg-slate-900 dark:bg-white text-white dark:text-slate-900 hover:bg-blue-600 dark:hover:bg-blue-600 hover:text-white shadow-black/5 hover:shadow-blue-600/20' %> py-3.5 px-6 rounded-2xl font-black text-xs flex items-center justify-center gap-2 transition-all duration-300 shadow-xl">
                    <span><%= type === 'script' ? './buy.sh' : (isDashboard ? 'Beli Sekarang' : 'Detail Produk') %></span>
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                </a>
            <% } %>
        </div>
    </div>
</div>
