<div x-data="{ 
    open: false, 
    messages: [], 
    input: '', 
    sessionId: localStorage.getItem('chatSessionId') || 'sess_' + Math.random().toString(36).substr(2, 9),
    currentUser: JSON.parse(decodeURIComponent('<%- encodeURIComponent(JSON.stringify((typeof user !== 'undefined' && user) ? { id: user.id, name: user.username || user.name || user.email } : null)) %>')),
    status: 'active',
    socket: null,
    isSocketMode: false,
    async init() {
        localStorage.setItem('chatSessionId', this.sessionId);
        
        if (typeof io !== 'undefined') {
            try {
                this.socket = io({
                    reconnectionAttempts: 2,
                    timeout: 4000
                });
                
                this.socket.on('connect', () => {
                    this.isSocketMode = true;
                    this.socket.emit('join-chat', { sessionId: this.sessionId, user: this.currentUser });
                });

                this.socket.on('chat-history', (history) => { 
                    this.messages = history; 
                    this.scrollToBottom(); 
                });

                this.socket.on('new-message', (msg) => { 
                    const isDuplicate = this.messages.some(m => m.content === msg.content && m.timestamp === msg.timestamp);
                    if (!isDuplicate) {
                        this.messages.push(msg); 
                        this.scrollToBottom();
                        if(!this.open && window.uiCore && window.uiCore.showToast) {
                            window.uiCore.showToast('Pesan baru dari dukungan', 'info');
                        }
                    }
                });

                this.socket.on('status-update', (s) => { this.status = s; });

                this.socket.on('connect_error', () => {
                    this.isSocketMode = false;
                    this.loadHistoryHttp();
                });
            } catch (err) {
                console.warn('Socket.io initialization error, falling back to HTTP:', err);
                this.isSocketMode = false;
                await this.loadHistoryHttp();
            }
        } else {
            console.warn('Socket.io is not available, using HTTP fallback');
            this.isSocketMode = false;
            await this.loadHistoryHttp();
        }
    },
    async loadHistoryHttp() {
        try {
            const res = await fetch(`/api/chat/history/${this.sessionId}`);
            const data = await res.json();
            if (data.success) {
                this.messages = data.messages;
                this.status = data.status || 'active';
                this.scrollToBottom();
            }
        } catch (err) {
            console.error('Failed to load chat history via HTTP:', err);
        }
    },
    async sendMessage() {
            if(!this.input.trim()) return;
        
            const text = this.input;
            this.input = ''; 
            // keep chat open after send
            this.open = true;

            const author = this.currentUser ? { id: this.currentUser.id, name: this.currentUser.name } : null;

            if (this.isSocketMode && this.socket) {
                this.socket.emit('send-message', { sessionId: this.sessionId, content: text, author });
            } else {
            const userMsg = { role: 'user', content: text, timestamp: new Date().toISOString() };
                // attach author locally so UI shows username immediately
                if (author) userMsg.author = author;
                this.messages.push(userMsg);
            this.scrollToBottom();

            try {
                const res = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sessionId: this.sessionId, content: text })
                });
                    const data = await res.json();
                    if (data.success) {
                        this.messages = data.messages;
                        this.scrollToBottom();
                    }
            } catch (err) {
                console.error('HTTP Send error:', err);
                if(window.uiCore && window.uiCore.showToast) {
                    window.uiCore.showToast('Gagal mengirim pesan', 'error');
                }
            }
        }
    },
    async requestAdmin() {
        if (this.isSocketMode && this.socket) {
            this.socket.emit('request-admin', { sessionId: this.sessionId });
            this.status = 'waiting_admin';
        } else {
            try {
                const res = await fetch('/api/chat/request-admin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sessionId: this.sessionId })
                });
                const data = await res.json();
                if (data.success) {
                    this.status = 'waiting_admin';
                }
            } catch (err) {
                console.error('Failed to request admin via HTTP:', err);
            }
        }
    },
    async resetChat() {
        if (this.isSocketMode && this.socket) {
            this.socket.emit('reset-chat', { sessionId: this.sessionId });
            this.messages = [];
            this.status = 'active';
        } else {
            try {
                const res = await fetch(`/api/chat/reset/${this.sessionId}`, { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    this.messages = [];
                    this.status = 'active';
                }
            } catch (err) {
                console.error('Failed to reset chat via HTTP:', err);
            }
        }
    },
    scrollToBottom() {
        setTimeout(() => {
            const container = document.getElementById('chat-messages-container');
            if(container) container.scrollTop = container.scrollHeight;
        }, 100);
    }
}" x-init="init()" class="fixed bottom-6 right-6 lg:bottom-10 lg:right-10 z-[100]">
    
    <!-- Pulse Effect for Button -->
    <div x-show="!open" class="absolute inset-0 bg-blue-500 rounded-full animate-ping opacity-25"></div>

    <!-- Toggle Button -->
    <button @click="open = !open" 
            class="relative w-16 h-16 bg-gradient-to-tr from-blue-600 to-indigo-500 text-white rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all duration-300 group ring-4 ring-blue-500/30 overflow-hidden">
        
        <!-- Shine effect -->
        <div class="absolute inset-0 w-full h-full bg-gradient-to-tr from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>

        <svg x-show="!open" class="w-7 h-7 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
        <svg x-show="open" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>

    <!-- Chat Window -->
    <div x-show="open" 
         x-transition:enter="transition ease-out duration-300 cubic-bezier(0.4, 0, 0.2, 1)"
         x-transition:enter-start="opacity-0 translate-y-12 scale-90"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 translate-y-0 scale-100"
         x-transition:leave-end="opacity-0 translate-y-12 scale-90"
         class="absolute bottom-24 right-0 w-[calc(100vw-3rem)] max-w-[380px] h-[550px] max-h-[calc(100vh-8rem)] bg-white/95 dark:bg-[#0B0E1A]/95 backdrop-blur-xl rounded-[2rem] shadow-2xl shadow-blue-900/20 border border-white/50 dark:border-white/10 flex flex-col overflow-hidden"
         x-cloak>
        
        <!-- Header -->
        <div class="relative p-6 bg-gradient-to-r from-blue-600 to-indigo-600 text-white flex items-center justify-between shrink-0 overflow-hidden">
            <!-- Decorative circles -->
            <div class="absolute -right-10 -top-10 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
            <div class="absolute -left-10 -bottom-10 w-32 h-32 bg-black/10 rounded-full blur-2xl"></div>
            
            <div class="relative flex items-center gap-4">
                <div class="w-12 h-12 bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center border border-white/30 shadow-inner">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                    <h3 class="font-black text-lg leading-tight tracking-tight">Asisten Cloud</h3>
                    <div class="flex items-center gap-1.5 mt-0.5">
                        <span class="relative flex h-2 w-2">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                        </span>
                        <p class="text-[11px] text-blue-100 font-bold uppercase tracking-wider" x-text="status === 'active' ? 'Online - AI' : 'Menunggu Admin'"></p>
                    </div>
                </div>
            </div>
            <div class="relative flex items-center gap-1">
                <button @click="if(confirm('Hapus riwayat chat?')) resetChat()" class="p-2.5 hover:bg-white/20 rounded-xl transition-all" title="Reset Chat">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </button>
                <button @click="open = false" class="p-2.5 hover:bg-white/20 rounded-xl transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
                </button>
            </div>
        </div>

        <!-- Messages -->
        <div id="chat-messages-container" class="flex-1 overflow-y-auto p-6 space-y-5 bg-slate-50/50 dark:bg-transparent scroll-smooth">
            <div class="text-center mb-6">
                <span class="inline-block px-3 py-1 bg-slate-200/50 dark:bg-white/5 rounded-full text-[10px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-widest border border-slate-300/50 dark:border-white/10">Percakapan Dimulai</span>
            </div>
            
            <template x-for="msg in messages">
                <div :class="msg.role === 'user' ? 'flex justify-end' : 'flex justify-start gap-3'">
                    
                    <!-- Avatar for support -->
                    <template x-if="msg.role !== 'user'">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center shrink-0 shadow-sm mt-1">
                            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                    </template>

                    <div class="flex flex-col max-w-[80%]" :class="msg.role === 'user' ? 'items-end' : 'items-start'">
                        <div class="flex items-center gap-2 mb-1" x-show="msg.author && msg.author.name">
                            <span class="text-[10px] font-bold text-slate-500" x-text="msg.author.name"></span>
                        </div>
                        <div :class="msg.role === 'user' ? 'bg-gradient-to-br from-blue-600 to-blue-500 text-white rounded-2xl rounded-tr-sm shadow-blue-500/20' : 'bg-white dark:bg-[#181C2A] text-slate-800 dark:text-slate-200 rounded-2xl rounded-tl-sm border border-slate-200 dark:border-white/10 shadow-sm'" 
                             class="px-5 py-3.5 shadow-lg">
                            <p class="text-sm font-semibold leading-relaxed" x-text="msg.content"></p>
                        </div>
                        <span class="text-[9px] font-bold text-slate-400 opacity-80 mt-1.5 px-1" x-text="new Date(msg.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})"></span>
                    </div>
                </div>
            </template>

            <div x-show="status === 'waiting_admin'" class="p-4 bg-blue-50 dark:bg-blue-500/10 rounded-2xl border border-blue-100 dark:border-blue-500/20 text-center animate-pulse">
                <p class="text-xs font-bold text-blue-600 dark:text-blue-400">Menghubungkan ke admin... Mohon tunggu sebentar.</p>
            </div>
        </div>

        <!-- Input -->
        <div class="p-4 sm:p-5 bg-white dark:bg-[#12121A] border-t border-slate-200 dark:border-slate-800/80 shrink-0">
            <div class="flex flex-col gap-3">
                <div x-show="status === 'active'" class="flex justify-center -mt-1">
                    <button @click="requestAdmin()" class="inline-flex items-center gap-1 text-[10px] font-black text-slate-400 hover:text-blue-500 dark:text-slate-500 dark:hover:text-blue-400 uppercase tracking-widest transition-colors">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        Bicara dengan Admin Manusia
                    </button>
                </div>
                <div class="flex gap-2">
                    <input type="text" x-model="input" @keydown.enter.prevent="sendMessage()" placeholder="Tulis pesan Anda..." class="flex-1 bg-slate-100 dark:bg-[#181C2A] border-2 border-transparent focus:border-blue-500/30 rounded-2xl px-5 py-3.5 text-sm font-bold text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:ring-0 transition-all outline-none">
                    <button @click="sendMessage()" class="bg-blue-600 text-white p-4 rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-xl shadow-blue-600/20 shrink-0">
                        <svg class="w-5 h-5 -rotate-45 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Socket.io Script -->
<script src="/socket.io/socket.io.js"></script>
