<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/output.css?v=2">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; }
        html { scroll-behavior: smooth; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .dark ::-webkit-scrollbar-thumb { background: #334155; }

        /* Toast notification styles */
        .toast-container { position: fixed; top: 80px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
        .toast { padding: 12px 20px; border-radius: 12px; font-size: 14px; font-weight: 600; color: white; box-shadow: 0 10px 40px -10px rgba(0,0,0,0.3); transform: translateX(120%); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1); max-width: 360px; }
        .toast.show { transform: translateX(0); }
        .toast-success { background: #10b981; }
        .toast-error { background: #ef4444; }
        .toast-info { background: #3b82f6; }

        /* Avatar pulse animation */
        @keyframes avatarPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.3); }
            50% { box-shadow: 0 0 0 12px rgba(59, 130, 246, 0); }
        }
        .avatar-pulse:hover {
            animation: avatarPulse 1.5s ease-in-out infinite;
        }

        /* Card hover lift */
        .card-lift {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .card-lift:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px -15px rgba(0,0,0,0.08);
        }
        .dark .card-lift:hover {
            box-shadow: 0 20px 40px -15px rgba(0,0,0,0.4);
        }
    </style>
    <script>
        window.uiCore = {
            toggleTheme: function () {
                document.documentElement.classList.toggle('dark');
                localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
            },
            toggleSidebar: function () {
                const sidebar = document.getElementById('app-sidebar');
                const overlay = document.getElementById('app-overlay');
                if (sidebar && overlay) {
                    sidebar.classList.toggle('-translate-x-full');
                    overlay.classList.toggle('hidden');
                    overlay.classList.toggle('opacity-0');
                }
            },
            showToast: function(message, type = 'info') {
                const container = document.getElementById('toast-container') || (() => {
                    const c = document.createElement('div');
                    c.id = 'toast-container';
                    c.className = 'toast-container';
                    document.body.appendChild(c);
                    return c;
                })();
                const toast = document.createElement('div');
                toast.className = 'toast toast-' + type;
                toast.textContent = message;
                container.appendChild(toast);
                requestAnimationFrame(() => { requestAnimationFrame(() => { toast.classList.add('show'); }); });
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 400);
                }, 4000);
            }
        };
        if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>
    <!-- Alpine.js -->
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js" defer></script>
    <style>[x-cloak] { display: none !important; }</style>

    <!-- HTMX for SPA -->
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
    <style>
        .htmx-indicator { opacity: 0; transition: opacity 200ms ease-in; }
        .htmx-request .htmx-indicator { opacity: 1; }
        .htmx-request.htmx-indicator { opacity: 1; }
        #nprogress { pointer-events: none; }
        #nprogress .bar { background: #3b82f6; position: fixed; z-index: 99999; top: 0; left: 0; width: 100%; height: 3px; }
    </style>
    <script src="https://unpkg.com/nprogress@0.2.0/nprogress.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/nprogress@0.2.0/nprogress.css" />
    <script>
        document.addEventListener('htmx:beforeRequest', function(evt) {
            NProgress.start();
        });
        document.addEventListener('htmx:afterOnLoad', function(evt) {
            NProgress.done();
        // Auto-close sidebar on mobile
        const sidebar = document.getElementById('app-sidebar');
        if (sidebar && !sidebar.classList.contains('-translate-x-full')) {
            window.uiCore.toggleSidebar();
        }

            if (window.AOS) {
                setTimeout(() => AOS.init({ duration: 600, easing: 'ease-out-cubic', once: true, offset: 40 }), 100);
            }
        });
    </script>

</head>

<body  class="bg-[#F4F7FA] dark:bg-[#09090B] text-slate-800 dark:text-slate-200 antialiased min-h-screen transition-colors duration-300" x-data="{ upgradeModal: false, confirmRegenerate: false, copied: false }">

    <!-- NAV BAR -->
    <%- include('../partials/dashboard-navbar') %>

    <%- include('../partials/user-sidebar') %>

    <main class="pt-16 min-h-screen flex flex-col w-full transition-all duration-300">
        <div class="p-4 sm:p-6 lg:p-8 flex-1 w-full max-w-7xl mx-auto space-y-6 sm:space-y-8">

            <div data-aos="fade-up" class="mb-2">
                <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Profil & Keamanan Akun</h1>
                <p class="text-sm font-medium text-slate-500 mt-1">Kelola preferensi akun, kunci pengembang API, dan margin reseller Anda.</p>
            </div>

            <div class="flex flex-col lg:flex-row gap-6 lg:gap-8 items-start w-full">

                <!-- Left Column (Profile & Balance) -->
                <div class="w-full lg:w-1/3 flex flex-col gap-6">
                    <!-- Profile Card -->
                    <div data-aos="fade-up" class="bg-white dark:bg-[#12121A] rounded-[2rem] p-8 border border-slate-200 dark:border-slate-800 shadow-sm text-center w-full card-lift hover:border-blue-500/30 transition-all duration-300">
                        <div class="w-24 h-24 bg-gradient-to-br from-blue-600 to-indigo-600 rounded-[2rem] mx-auto mb-5 flex items-center justify-center text-3xl font-black text-white shadow-lg shadow-blue-600/20 avatar-pulse cursor-default transition-all duration-300">
                            <%= user.username.charAt(0).toUpperCase() %>
                        </div>
                        <h2 class="text-xl font-black text-slate-900 dark:text-white tracking-tight"><%= user.username %></h2>
                        <p class="text-xs font-bold text-slate-400 mt-0.5 break-all"><%= user.email %></p>
                        
                        <div class="mt-4">
                            <span class="inline-block px-4 py-1.5 bg-blue-50 dark:bg-blue-600/10 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 rounded-xl text-[9px] font-black uppercase tracking-widest"><%= user.role %></span>
                        </div>
                        
                        <div class="mt-8 pt-6 border-t border-slate-100 dark:border-slate-800">
                            <a href="/auth/logout" class="flex items-center justify-center gap-2.5 w-full py-3.5 px-4 rounded-2xl bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 font-black text-xs hover:bg-red-100 dark:hover:bg-red-500/20 transition-all duration-200 group active:scale-95 border border-red-100/50 dark:border-red-500/20">
                                <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                                Keluar Akun
                            </a>
                        </div>
                    </div>

                    <!-- Balance Card -->
                    <div data-aos="fade-up" data-aos-delay="100" class="bg-white dark:bg-[#12121A] rounded-[2rem] p-6 lg:p-8 border border-slate-200 dark:border-slate-800 shadow-sm w-full card-lift hover:border-blue-500/30 transition-all duration-300">
                        <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 mb-2 uppercase tracking-widest">Akun Balance</span>
                        <p class="text-slate-400 dark:text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1.5">Sisa Saldo Anda</p>
                        <div class="text-3xl font-black text-slate-900 dark:text-white break-all tracking-tight">Rp <%= user.balance.toLocaleString('id-ID') %></div>
                        <a href="/dashboard/topup" class="text-blue-600 dark:text-blue-400 text-xs font-black uppercase tracking-widest mt-5 inline-flex items-center gap-1 hover:gap-2 transition-all">Topup Saldo <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg></a>
                    </div>
                </div>

                <!-- Right Column (Reseller Actions & Settings) -->
                <div class="w-full lg:w-2/3 flex flex-col gap-6">
                    <% if (user.role==='user' ) { %>
                        <!-- Upgrade to Reseller Card -->
                        <div data-aos="fade-up" data-aos-delay="200" class="bg-white dark:bg-[#12121A] rounded-[2rem] p-6 sm:p-8 border border-slate-200 dark:border-slate-800 shadow-sm w-full card-lift hover:border-blue-500/30 transition-all duration-300">
                            <h2 class="text-xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Jadilah Reseller Resmi 🚀</h2>
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-8 leading-relaxed max-w-2xl">Dapatkan akses kunci API eksklusif, harga produk jauh lebih murah dibanding harga publik, serta aktifkan fitur markup margin untuk client bot/website jualan Anda sendiri.</p>

                            <div class="bg-slate-50 dark:bg-slate-900/50 rounded-2xl p-5 sm:p-6 border border-slate-100 dark:border-slate-800/80 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
                                <div>
                                    <span class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Biaya Upgrade (Sekali Bayar)</span>
                                    <span class="text-2xl font-black text-slate-900 dark:text-white">Rp <%= upgradePrice.toLocaleString('id-ID') %></span>
                                </div>
                                <button type="button" @click="upgradeModal = true" class="w-full sm:w-auto bg-blue-600 hover:bg-blue-500 text-white font-black py-4.5 px-8 rounded-xl transition-all duration-300 active:scale-[0.96] shadow-lg shadow-blue-600/20 hover:shadow-blue-500/40 hover:-translate-y-0.5 text-xs uppercase tracking-widest">Upgrade Sekarang</button>
                            </div>

                            <!-- Upgrade Confirmation Modal -->
                            <div x-show="upgradeModal" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 z-50 flex items-center justify-center p-4" style="display: none;">
                                <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" @click="upgradeModal = false"></div>
                                <div x-show="upgradeModal" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95 translate-y-4" x-transition:enter-end="opacity-100 scale-100 translate-y-0" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100 scale-100 translate-y-0" x-transition:leave-end="opacity-0 scale-95 translate-y-4" class="relative w-full max-w-md bg-white dark:bg-[#12121A] rounded-[24px] p-6 sm:p-8 border border-slate-200 dark:border-slate-800 shadow-2xl z-10">
                                    <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Konfirmasi Upgrade Reseller</h3>
                                    <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-8 leading-relaxed">Tindakan ini akan memotong saldo akun Anda sebesar <strong class="text-slate-900 dark:text-white">Rp <%= upgradePrice.toLocaleString('id-ID') %></strong> secara permanen. Apakah Anda yakin?</p>
                                    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
                                        <button type="button" @click="upgradeModal = false" class="flex-1 px-6 py-3.5 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-all duration-200 active:scale-95">Batalkan</button>
                                        <form action="/dashboard/profile/upgrade" method="POST" class="flex-1 m-0">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="w-full h-full bg-blue-600 hover:bg-blue-500 text-white font-black py-3.5 px-6 rounded-xl transition-all duration-300 shadow-lg shadow-blue-600/20 hover:shadow-blue-500/40 active:scale-95">Setujui</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } else if (user.role==='reseller' || user.role==='admin' || user.role==='owner' ) { %>
                        <!-- API Credentials -->
                        <div data-aos="fade-up" data-aos-delay="200" class="bg-white dark:bg-[#12121A] rounded-[2rem] p-6 sm:p-8 border border-slate-200 dark:border-slate-800 shadow-sm w-full card-lift hover:border-blue-500/30 transition-all duration-300">
                            <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 mb-2 uppercase tracking-widest">API Integrasi</span>
                            <h3 class="text-lg font-black text-slate-900 dark:text-white mb-2 tracking-tight">Kunci API Reseller (API Key)</h3>
                            <p class="text-sm font-medium text-slate-500 mb-6 max-w-2xl">Gunakan Kunci API ini untuk mengintegrasikan layanan pembelian server ke program bot/website Anda. Kirimkan via header HTTP <code class="px-2 py-1 rounded-lg bg-slate-100 dark:bg-slate-800 font-mono text-xs text-blue-600 dark:text-blue-400 font-bold">x-api-key</code>.</p>

                            <div class="flex flex-col sm:flex-row gap-4 items-stretch w-full">
                                <div class="flex-1 relative w-full">
                                    <input id="apiKeyField" type="text" readonly value="<%= user.apiKey || 'Belum di-generate' %>" class="w-full bg-slate-55 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-5 py-4 text-sm font-mono font-bold text-slate-700 dark:text-slate-300 focus:outline-none pr-24">
                                    <button type="button" @click="navigator.clipboard.writeText(document.getElementById('apiKeyField').value); copied = true; window.uiCore.showToast('API key berhasil disalin!', 'success'); setTimeout(() => copied = false, 2000)" class="absolute right-2.5 top-1/2 -translate-y-1/2 px-3 py-2 rounded-lg bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-black hover:bg-blue-100 dark:hover:bg-blue-500/20 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-200 active:scale-95 uppercase tracking-widest">
                                        <span x-show="!copied">Salin</span>
                                        <span x-show="copied" x-transition>Salin!</span>
                                    </button>
                                </div>
                                <div class="w-full sm:w-auto flex-shrink-0">
                                    <button type="button" @click="confirmRegenerate = true" class="w-full h-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-black py-4 px-8 rounded-xl hover:bg-slate-800 dark:hover:bg-slate-100 transition-all duration-300 active:scale-95 text-xs uppercase tracking-widest shadow-lg">Buat Baru</button>
                                </div>
                            </div>
                        </div>

                        <!-- Global Markup Margin -->
                        <div data-aos="fade-up" data-aos-delay="300" class="bg-white dark:bg-[#12121A] rounded-[2rem] p-6 sm:p-8 border border-slate-200 dark:border-slate-800 shadow-sm w-full card-lift hover:border-blue-500/30 transition-all duration-300">
                            <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-100 dark:border-emerald-500/20 mb-2 uppercase tracking-widest">Keuntungan</span>
                            <h3 class="text-lg font-black text-slate-900 dark:text-white mb-2 tracking-tight">Atur Global Markup Margin</h3>
                            <p class="text-sm font-medium text-slate-500 mb-6 max-w-2xl">Atur selisih/tambahan nominal harga (keuntungan bersih) yang otomatis ditambahkan di atas harga dasar semua produk Pterodactyl khusus saat dipesan via API.</p>

                            <form action="/dashboard/profile/margin" method="POST" class="flex flex-col sm:flex-row gap-4 w-full m-0">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <div class="flex-1 relative w-full">
                                    <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none"><span class="text-slate-400 font-black text-sm">Rp</span></div>
                                    <input type="number" name="margin" value="<%= user.marginReseller || 0 %>" min="0" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl pl-12 pr-5 py-4 text-slate-900 dark:text-white font-black text-lg focus:ring-2 focus:ring-blue-500 focus:outline-none transition-all duration-300">
                                </div>
                                <button type="submit" class="w-full sm:w-auto bg-blue-600 hover:bg-blue-500 text-white font-black py-4 px-10 rounded-xl transition-all duration-300 active:scale-95 shadow-lg shadow-blue-600/20 hover:shadow-blue-500/40 hover:-translate-y-0.5 flex-shrink-0 text-xs uppercase tracking-widest">Simpan Pengaturan</button>
                            </form>
                        </div>
                    <% } %>
                </div>

            </div>
        </div>
    </main>

    <!-- API Key Regenerate Confirmation Modal -->
    <div x-show="confirmRegenerate" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 z-50 flex items-center justify-center p-4" style="display: none;">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" @click="confirmRegenerate = false"></div>
        <div x-show="confirmRegenerate" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95 translate-y-4" x-transition:enter-end="opacity-100 scale-100 translate-y-0" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100 scale-100 translate-y-0" x-transition:leave-end="opacity-0 scale-95 translate-y-4" class="relative w-full max-w-md bg-white dark:bg-[#12121A] rounded-[24px] p-6 sm:p-8 border border-slate-200 dark:border-slate-800 shadow-2xl z-10">
            <div class="w-12 h-12 bg-amber-50 dark:bg-amber-500/10 rounded-2xl flex items-center justify-center text-amber-600 dark:text-amber-400 mb-4 shadow-inner">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path></svg>
            </div>
            <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Konfirmasi Buat Kunci API Baru</h3>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-8 leading-relaxed">Membuat kunci baru akan <strong class="text-red-600 dark:text-red-400">menghapus secara instan</strong> kunci lama Anda. Seluruh bot/website jualan yang masih memakai kunci lama akan kehilangan akses. Lanjutkan?</p>
            <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
                <button type="button" @click="confirmRegenerate = false" class="flex-1 px-6 py-3.5 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-all duration-200 active:scale-95">Batalkan</button>
                <form action="/dashboard/profile/generate-key" method="POST" class="flex-1 m-0">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="w-full h-full bg-red-600 hover:bg-red-500 text-white font-black py-3.5 px-6 rounded-xl transition-all duration-300 shadow-lg shadow-red-600/20 active:scale-95">Ya, Buat Baru</button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 600, easing: 'ease-out-cubic', once: true, offset: 40 });
    </script>
</body>

</html>

