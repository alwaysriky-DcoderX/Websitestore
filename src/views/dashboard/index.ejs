<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/output.css?v=2">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js" defer></script>
    <style>
        [x-cloak] { display: none !important; }
        body { font-family: 'Outfit', sans-serif; }
        html { scroll-behavior: smooth; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .dark ::-webkit-scrollbar-thumb { background: #334155; }

        /* Toast notification styles */
        .toast-container { position: fixed; top: 80px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
        .toast { padding: 12px 20px; border-radius: 12px; font-size: 14px; font-weight: 600; color: white; box-shadow: 0 10px 40px -10px rgba(0,0,0,0.3); transform: translateX(120%); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1); max-width: 360px; }
        .toast.show { transform: translateX(0); }
        .toast-success { background: #10b981; }
        .toast-error { background: #ef4444; }
        .toast-info { background: #3b82f6; }

        /* Pulsing glow animation on welcome banner */
        @keyframes glowPulse {
            0%, 100% { opacity: 0.2; transform: translate(-50%, -50%) scale(1); }
            50% { opacity: 0.35; transform: translate(-50%, -50%) scale(1.1); }
        }
        .glow-pulse {
            animation: glowPulse 4s ease-in-out infinite;
        }

        /* Table row smooth slide-in */
        .table-row-animate {
            transition: all 0.2s cubic-bezier(0.4,0,0.2,1);
        }
        .table-row-animate:hover {
            background-color: rgba(241, 245, 249, 0.5);
            transform: translateX(2px);
        }
        .dark .table-row-animate:hover {
            background-color: rgba(30, 41, 59, 0.4);
        }
    </style>
    <script>
        window.uiCore = {
            toggleTheme: function () {
                document.documentElement.classList.toggle('dark');
                localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
            },
            toggleSidebar: function () {
                const sidebar = document.getElementById('app-sidebar');
                const overlay = document.getElementById('app-overlay');
                if (sidebar && overlay) {
                    sidebar.classList.toggle('-translate-x-full');
                    overlay.classList.toggle('hidden');
                    overlay.classList.toggle('opacity-0');
                }
            },
            showToast: function(message, type = 'info') {
                const container = document.getElementById('toast-container') || (() => {
                    const c = document.createElement('div');
                    c.id = 'toast-container';
                    c.className = 'toast-container';
                    document.body.appendChild(c);
                    return c;
                })();
                const toast = document.createElement('div');
                toast.className = 'toast toast-' + type;
                toast.textContent = message;
                container.appendChild(toast);
                requestAnimationFrame(() => { requestAnimationFrame(() => { toast.classList.add('show'); }); });
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 400);
                }, 4000);
            }
        };
        if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>

    <!-- HTMX for SPA -->
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
    <style>
        .htmx-indicator { opacity: 0; transition: opacity 200ms ease-in; }
        .htmx-request .htmx-indicator { opacity: 1; }
        .htmx-request.htmx-indicator { opacity: 1; }
        #nprogress { pointer-events: none; }
        #nprogress .bar { background: #3b82f6; position: fixed; z-index: 99999; top: 0; left: 0; width: 100%; height: 3px; }
    </style>
    <script src="https://unpkg.com/nprogress@0.2.0/nprogress.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/nprogress@0.2.0/nprogress.css" />
    <script>
        document.addEventListener('htmx:beforeRequest', function(evt) {
            NProgress.start();
        });
        document.addEventListener('htmx:afterOnLoad', function(evt) {
            NProgress.done();
        // Auto-close sidebar on mobile
        const sidebar = document.getElementById('app-sidebar');
        if (sidebar && !sidebar.classList.contains('-translate-x-full')) {
            window.uiCore.toggleSidebar();
        }

            if (window.AOS) {
                setTimeout(() => AOS.init({ duration: 600, easing: 'ease-out-cubic', once: true, offset: 40 }), 100);
            }
        });
    </script>

</head>

<body  class="bg-[#F4F7FA] dark:bg-[#09090B] text-slate-800 dark:text-slate-200 antialiased min-h-screen transition-colors duration-300">

    <!-- NAV BAR -->
    <%- include('../partials/dashboard-navbar') %>

    <%- include('../partials/user-sidebar') %>

    <main class="pt-16 min-h-screen flex flex-col w-full transition-all duration-300">
        <div class="p-4 sm:p-6 lg:p-8 flex-1 w-full max-w-7xl mx-auto space-y-6 sm:space-y-8">

            <!-- Premium Glassmorphic Welcome Banner -->
            <div data-aos="fade-up" class="relative overflow-hidden bg-gradient-to-br from-[#1E293B] via-[#0F172A] to-[#020617] dark:from-[#111119] dark:via-[#09090E] dark:to-[#020205] rounded-[2rem] p-8 sm:p-10 border border-slate-800/80 shadow-2xl transition-all duration-300">
                <!-- Background decorative glowing orbs -->
                <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-gradient-to-br from-blue-600/20 to-purple-600/10 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/3 pointer-events-none glow-pulse"></div>
                <div class="absolute -bottom-20 -left-20 w-[300px] h-[300px] bg-emerald-500/10 rounded-full blur-[80px] pointer-events-none glow-pulse" style="animation-delay: 1.5s;"></div>

                <div class="relative z-10 flex flex-col lg:flex-row lg:items-center justify-between gap-8">
                    <div class="space-y-4">
                        <span class="inline-flex items-center gap-1.5 py-1 px-3 rounded-full text-[9px] font-black bg-blue-500/15 text-blue-400 border border-blue-500/20 tracking-widest uppercase">Member Dashboard</span>
                        <div>
                            <h2 class="text-3xl sm:text-4xl font-black text-white tracking-tight mb-2">Selamat datang kembali, <%= user.username %> 👋</h2>
                            <p class="text-slate-400 text-sm sm:text-base font-medium max-w-lg leading-relaxed">Kelola server Pterodactyl, script, aplikasi premium, dan transaksi saldo Anda secara instan dan otomatis.</p>
                        </div>
                    </div>
                    
                    <!-- Balance Display & Topup Button -->
                    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 w-full lg:w-auto">
                        <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-5 flex-1 sm:min-w-[240px] hover:bg-white/10 transition-all duration-300 shadow-inner group">
                            <p class="text-blue-400 text-[9px] font-black uppercase tracking-widest mb-1.5 flex items-center gap-1">
                                <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
                                Saldo Akun Anda
                            </p>
                            <div class="text-3xl font-black text-white tracking-tight group-hover:scale-105 transition-transform duration-300">Rp <%= user.balance.toLocaleString('id-ID') %></div>
                        </div>
                        <a href="/dashboard/topup" class="bg-blue-600 hover:bg-blue-500 text-white rounded-2xl p-5 flex items-center justify-center gap-3 font-black transition-all duration-300 active:scale-[0.96] shadow-lg shadow-blue-600/20 hover:shadow-blue-500/40 hover:-translate-y-1">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path></svg>
                            <span class="sm:hidden font-bold">Isi Saldo</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Interactive Premium Stats Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Stat Card 1: Reseller/Upgrade -->
                <% if (user.role==='reseller' || user.role==='admin' || user.role==='owner' ) { %>
                    <div data-aos="fade-up" data-aos-delay="0" class="bg-white dark:bg-[#12121A] rounded-3xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between group hover:border-blue-500 dark:hover:border-blue-500/50 hover:shadow-xl hover:shadow-blue-500/5 hover:-translate-y-1.5 transition-all duration-300">
                        <div>
                            <div class="w-12 h-12 bg-emerald-50 dark:bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-600 dark:text-emerald-400 mb-5 group-hover:scale-110 transition-transform duration-300 shadow-sm">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                            </div>
                            <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-100 dark:border-emerald-500/20 mb-2 uppercase tracking-widest">Reseller Aktif</span>
                            <p class="text-slate-400 dark:text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1">Keuntungan Margin Anda</p>
                            <h4 class="text-2xl font-black text-slate-900 dark:text-white">Rp <%= (user.marginReseller || 0).toLocaleString('id-ID') %></h4>
                        </div>
                        <a href="/dashboard/profile" class="text-emerald-600 dark:text-emerald-400 font-black text-xs mt-5 inline-flex items-center gap-1 hover:gap-2 transition-all">Atur Margin Reseller <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg></a>
                    </div>
                <% } else { %>
                    <div data-aos="fade-up" data-aos-delay="0" class="relative overflow-hidden bg-white dark:bg-[#12121A] rounded-3xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between group hover:border-blue-500 dark:hover:border-blue-500/50 hover:shadow-xl hover:shadow-blue-500/5 hover:-translate-y-1.5 transition-all duration-300">
                        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-blue-600/10 to-transparent rounded-bl-full pointer-events-none"></div>
                        <div>
                            <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center text-white mb-5 shadow-lg shadow-blue-600/20 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                            </div>
                            <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 mb-2 uppercase tracking-widest">Upgrade Akun</span>
                            <h4 class="text-lg font-black text-slate-900 dark:text-white leading-snug">Jadilah Reseller Resmi & Dapatkan Harga Lebih Murah!</h4>
                        </div>
                        <a href="/dashboard/profile" class="text-blue-600 dark:text-blue-400 font-black text-xs mt-5 inline-flex items-center gap-1 hover:gap-2 transition-all">Lihat Keuntungan <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg></a>
                    </div>
                <% } %>

                <!-- Stat Card 2: API Reference -->
                <div data-aos="fade-up" data-aos-delay="100" class="bg-white dark:bg-[#12121A] rounded-3xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between group cursor-pointer hover:border-blue-500 dark:hover:border-blue-500/50 hover:shadow-xl hover:shadow-blue-500/5 hover:-translate-y-1.5 transition-all duration-300" onclick="window.location.href='/docs'">
                    <div>
                        <div class="w-12 h-12 bg-slate-100 dark:bg-slate-800 rounded-2xl flex items-center justify-center text-slate-600 dark:text-slate-300 mb-5 group-hover:bg-blue-50 dark:group-hover:bg-blue-500/10 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-300 shadow-sm">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                        </div>
                        <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700/50 mb-2 uppercase tracking-widest">Developer Toolkit</span>
                        <p class="text-slate-400 dark:text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1">Integrasi Sistem & Reseller</p>
                        <h4 class="text-xl font-black text-slate-900 dark:text-white">REST API Dokumentasi</h4>
                    </div>
                    <span class="text-slate-900 dark:text-white font-black text-xs mt-5 inline-flex items-center gap-1 group-hover:gap-2 transition-all">Buka Dokumentasi <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg></span>
                </div>

                <!-- Stat Card 3: Total Operations -->
                <div data-aos="fade-up" data-aos-delay="200" class="bg-white dark:bg-[#12121A] rounded-3xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between group hover:border-blue-500 dark:hover:border-blue-500/50 hover:shadow-xl hover:shadow-blue-500/5 hover:-translate-y-1.5 transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 bg-slate-100 dark:bg-slate-800 rounded-2xl flex items-center justify-center text-slate-600 dark:text-slate-300 mb-5 group-hover:scale-110 transition-transform duration-300 shadow-sm">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        </div>
                        <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700/50 mb-2 uppercase tracking-widest">Transaction History</span>
                        <p class="text-slate-400 dark:text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1">Total Pesanan Diproses</p>
                        <h4 class="text-3xl font-black text-slate-900 dark:text-white"><%= orders.length %> <span class="text-xs text-slate-400 font-bold">Transaksi</span></h4>
                    </div>
                    <span class="text-slate-500 dark:text-slate-400 font-bold text-xs mt-5 inline-flex items-center gap-1 select-none">Terekam di Database</span>
                </div>
            </div>

            <!-- Recent Activity Table Section -->
            <div data-aos="fade-up" data-aos-delay="100" class="bg-white dark:bg-[#12121A] rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden flex flex-col transition-colors">
                <div class="p-6 border-b border-slate-100 dark:border-slate-800/60 flex items-center justify-between">
                    <div>
                        <h3 class="text-xl font-black text-slate-900 dark:text-white tracking-tight">Aktivitas Transaksi Terakhir</h3>
                        <p class="text-xs font-medium text-slate-400 dark:text-slate-500 mt-1">Catatan pemesanan dan pengeluaran saldo yang Anda lakukan di platform kami.</p>
                    </div>
                </div>
                <div class="overflow-x-auto w-full">
                    <table class="w-full text-left border-collapse whitespace-nowrap min-w-[600px]">
                        <thead>
                            <tr class="bg-slate-50/50 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800/60">
                                <th class="py-4 px-6 text-slate-400 dark:text-slate-500 font-black text-[10px] uppercase tracking-widest">ID Transaksi</th>
                                <th class="py-4 px-6 text-slate-400 dark:text-slate-500 font-black text-[10px] uppercase tracking-widest">Produk / Layanan</th>
                                <th class="py-4 px-6 text-slate-400 dark:text-slate-500 font-black text-[10px] uppercase tracking-widest">Total Biaya</th>
                                <th class="py-4 px-6 text-slate-400 dark:text-slate-500 font-black text-[10px] uppercase tracking-widest text-center">Status Proses</th>
                                <th class="py-4 px-6 text-slate-400 dark:text-slate-500 font-black text-[10px] uppercase tracking-widest text-right">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                            <% if (orders.length===0) { %>
                                <tr><td colspan="5" class="py-16 text-center">
                                    <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-slate-100 dark:bg-slate-800 mb-4 transition-colors">
                                        <svg class="w-6 h-6 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                                    </div>
                                    <p class="text-slate-500 dark:text-slate-400 text-sm font-bold">Belum ada riwayat aktivitas transaksi.</p>
                                </td></tr>
                            <% } else { %>
                                <% orders.forEach(order=> { %>
                                    <tr class="table-row-animate hover:bg-slate-50/50 dark:hover:bg-slate-800/40 transition-all duration-200">
                                        <td class="py-5 px-6">
                                            <div class="flex items-center gap-3">
                                                <div class="w-9 h-9 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center text-slate-500 dark:text-slate-400 text-xs font-black font-mono">#</div>
                                                <div>
                                                    <div class="font-mono text-sm font-black text-slate-900 dark:text-slate-200"><%= order.orderId %></div>
                                                    <div class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mt-0.5"><%= new Date(order.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-5 px-6">
                                            <div class="text-sm font-black text-slate-900 dark:text-slate-200"><%= order.productNameSnap %></div>
                                            <div class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mt-0.5">Gerbang: <%= order.paymentGateway %></div>
                                        </td>
                                        <td class="py-5 px-6">
                                            <div class="text-sm font-black text-slate-900 dark:text-white">Rp <%= order.amount.toLocaleString('id-ID') %></div>
                                        </td>
                                        <td class="py-5 px-6 text-center">
                                            <% if (order.status==='completed' ) { %>
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 text-[10px] font-black uppercase tracking-widest border border-emerald-100 dark:border-emerald-500/20"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>Sukses</span>
                                            <% } else if (order.status==='pending' ) { %>
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-amber-50 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 text-[10px] font-black uppercase tracking-widest border border-amber-100 dark:border-amber-500/20"><span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>Pending</span>
                                            <% } else { %>
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 text-[10px] font-black uppercase tracking-widest border border-red-100 dark:border-red-500/20"><span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>Gagal</span>
                                            <% } %>
                                        </td>
                                        <td class="py-5 px-6 text-right font-bold">
                                            <% if (order.status === 'pending') { %>
                                                <% if (order.orderId.startsWith('OTP-')) { %>
                                                    <a href="/dashboard/marketplace?resumeOrder=<%= order.id %>" class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-amber-500 hover:bg-amber-600 text-white rounded-xl text-[10px] font-black tracking-wide shadow-md shadow-amber-500/10 active:scale-95 transition-all">
                                                        <span>Pantau OTP</span>
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                    </a>
                                                <% } else { %>
                                                    <a href="/dashboard/orders/pay/<%= order.id %>" class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-xl text-[10px] font-black tracking-wide shadow-md shadow-blue-600/10 active:scale-95 transition-all">
                                                        <span>Bayar</span>
                                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                                    </a>
                                                <% } %>
                                            <% } else if (order.status === 'completed') { %>
                                                <% if (order.orderId.startsWith('OTP-')) { %>
                                                    <a href="/dashboard/marketplace?resumeOrder=<%= order.id %>" class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl text-[10px] font-black tracking-wide shadow-md shadow-emerald-500/10 active:scale-95 transition-all">
                                                        <span>Detail OTP</span>
                                                    </a>
                                                <% } else { %>
                                                    <a href="/dashboard/orders/<%= order.id %>" class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-xl text-[10px] font-black tracking-wide active:scale-95 transition-all">
                                                        <span>Detail</span>
                                                    </a>
                                                <% } %>
                                            <% } else { %>
                                                <span class="text-[10px] font-bold text-slate-400">Gagal</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 600, easing: 'ease-out-cubic', once: true, offset: 40 });
    </script>
    
    <%- include('../partials/chat-widget') %>
</body>

</html>

