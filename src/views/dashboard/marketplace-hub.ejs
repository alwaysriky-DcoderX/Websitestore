<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../partials/head') %>
</head>
<body  class="bg-[#F4F7FA] dark:bg-[#09090B] text-slate-800 dark:text-slate-200 antialiased min-h-screen transition-colors duration-300">

    <%- include('../partials/dashboard-navbar') %>
    <%- include('../partials/user-sidebar') %>

<div class="sm:ml-64 bg-slate-50 dark:bg-[#0B0E1A] min-h-screen text-slate-800 dark:text-slate-200 transition-colors duration-300">
    <main class="pt-16 min-h-screen flex flex-col w-full transition-all duration-300">
        <div class="p-4 sm:p-6 lg:p-8 flex-1 w-full max-w-7xl mx-auto space-y-6 sm:space-y-8">
            <!-- Header -->
            <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-6 pb-6 border-b border-slate-200/50 dark:border-slate-800/50">
                <div data-aos="fade-right">
                    <span class="inline-flex items-center gap-1.5 py-1 px-3 rounded-full text-[10px] font-black bg-blue-50 dark:bg-blue-600/10 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-600/20 mb-2.5 uppercase tracking-wider">Premium Store</span>
                    <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight"><%= title %></h1>
                    <p class="text-sm font-medium text-slate-500 mt-1">Pilih kategori layanan yang Anda butuhkan.</p>
                </div>
            </div>

            <!-- Categories Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- SMM Panel -->
                <a href="/dashboard/marketplace/smm" class="group relative bg-white dark:bg-[#12121A] rounded-[2rem] p-8 border border-slate-200 dark:border-slate-800 hover:border-blue-500 dark:hover:border-blue-500 transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 block">
                    <div class="w-16 h-16 bg-blue-100 dark:bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-600 dark:text-blue-400 mb-6 group-hover:scale-110 transition-transform">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.514"></path></svg>
                    </div>
                    <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">SMM Panel</h3>
                    <p class="text-sm text-slate-500 font-medium">Layanan social media marketing, followers, likes, views untuk berbagai platform.</p>
                </a>

                <!-- Nokos / OTP -->
                <a href="/dashboard/marketplace/otp" class="group relative bg-white dark:bg-[#12121A] rounded-[2rem] p-8 border border-slate-200 dark:border-slate-800 hover:border-emerald-500 dark:hover:border-emerald-500 transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 block">
                    <div class="w-16 h-16 bg-emerald-100 dark:bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-600 dark:text-emerald-400 mb-6 group-hover:scale-110 transition-transform">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                    </div>
                    <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">Nokos / OTP</h3>
                    <p class="text-sm text-slate-500 font-medium">Layanan nomor virtual untuk verifikasi OTP berbagai aplikasi (WhatsApp, Telegram, dll).</p>
                </a>

                <!-- Pterodactyl -->
                <a href="/dashboard/marketplace/ptero" class="group relative bg-white dark:bg-[#12121A] rounded-[2rem] p-8 border border-slate-200 dark:border-slate-800 hover:border-purple-500 dark:hover:border-purple-500 transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 block">
                    <div class="w-16 h-16 bg-purple-100 dark:bg-purple-500/10 rounded-2xl flex items-center justify-center text-purple-600 dark:text-purple-400 mb-6 group-hover:scale-110 transition-transform">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path></svg>
                    </div>
                    <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">Panel Pterodactyl</h3>
                    <p class="text-sm text-slate-500 font-medium">Sewa layanan server hosting game Pterodactyl dengan kualitas premium.</p>
                </a>
            </div>
        </div>
    </main>
</div>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({ duration: 600, easing: 'ease-out-cubic', once: true, offset: 40 });
</script>
</body>
</html>
