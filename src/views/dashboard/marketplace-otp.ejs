<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../partials/head') %>
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .card-glow:hover {
            box-shadow: 0 20px 40px -15px rgba(59, 130, 246, 0.15);
            border-color: rgba(59, 130, 246, 0.25);
        }

        @keyframes pulseGlow {
            0%, 100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); }
            50% { box-shadow: 0 0 0 8px rgba(59, 130, 246, 0); }
        }
        .pulse-glow {
            animation: pulseGlow 2s infinite;
        }

        @keyframes progress {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        .progress-animate {
            animation: progress 2.5s infinite linear;
        }

        @keyframes pulseDot {
            0%, 100% { opacity: .2; transform: scale(0.8); }
            50% { opacity: 1; transform: scale(1.2); }
        }
        .dot-pulse span {
            animation: pulseDot 1.4s infinite ease-in-out both;
        }
        .dot-pulse span:nth-child(2) { animation-delay: .2s; }
        .dot-pulse span:nth-child(3) { animation-delay: .4s; }
    </style>
</head>
<body  class="bg-[#F4F7FA] dark:bg-[#09090B] text-slate-800 dark:text-slate-200 antialiased min-h-screen transition-colors duration-300">

    <%- include('../partials/dashboard-navbar') %>
    <%- include('../partials/user-sidebar') %>

    <% 
      const nokosCategory = categories.find(c => c.type === 'otp');
      const nokosCatId = nokosCategory ? nokosCategory.id : 'nokos_virtual_cat';
      const nokosProducts = products.filter(p => p.category && p.category.type === 'otp');
      
      const smmCategoryDb = categories.find(c => c.type === 'smm');
      const smmCatId = smmCategoryDb ? smmCategoryDb.id : 'smm_virtual_cat';
      const smmCategoriesSet = new Set();
      let smmServicesSafe = [];
      if (typeof smmServices !== 'undefined' && Array.isArray(smmServices)) {
          smmServicesSafe = smmServices;
          smmServices.forEach(s => {
              if (s.category) smmCategoriesSet.add(s.category);
          });
      }
      const smmServiceCategories = Array.from(smmCategoriesSet).sort();
      
      const requestedType = 'otp';
      let initialTab = 'all';
      let pageTitle = 'Marketplace';
      let pageSubtitle = 'Pilih dan deploy server instan maupun akun aplikasi premium pilihan Anda.';
      if (requestedType) {
          const matchingCat = categories.find(c => c.type === requestedType);
          if (matchingCat) {
              initialTab = matchingCat.id;
              pageTitle = matchingCat.name;
              pageSubtitle = 'Layanan ' + matchingCat.name + ' terbaik untuk Anda.';
          } else {
              if (requestedType === 'pterodactyl') pageTitle = 'Panel Pterodactyl';
              else if (requestedType === 'smm') { pageTitle = 'SMM Panel'; initialTab = smmCatId; }
              else if (requestedType === 'otp') { pageTitle = 'Nokos / OTP'; initialTab = nokosCatId; }
              else if (requestedType === 'script') pageTitle = 'Script & Source Code';
              else if (requestedType === 'premium_app') pageTitle = 'Aplikasi Premium';
          }
      }
    %>

    <div class="sm:ml-64 bg-slate-50 dark:bg-[#0B0E1A] min-h-screen text-slate-800 dark:text-slate-200 transition-colors duration-300">
        <main class="pt-16 min-h-screen flex flex-col w-full transition-all duration-300">
        <div class="p-4 sm:p-6 lg:p-8 flex-1 w-full max-w-7xl mx-auto space-y-6 sm:space-y-8" x-data="{ 
            activeTab: '<%= initialTab %>',
            searchQuery: '',
            activeNode: 'all',

            // Nokos Inline Checkout State
            selectedNokosProduct: null,
            nokosCountries: [],
            nokosSearch: '',
            loadingCountries: false,
            loadingOrder: false,
            selectedCountryName: '',
            
            // Order Monitoring State
            showStatus: false,
            phoneNumber: 'Memuat...',
            otpCode: '------',
            otpReceived: false,
            monitorInterval: null,
            orderId: null,

            // Payment & QRIS State
            showPaymentModal: false,
            selectedRate: null,
            showQrisModal: false,
            qrisString: '',
            qrisOrderId: '',
            qrisInterval: null,

            async init() {
                const urlParams = new URLSearchParams(window.location.search);
                const resumeId = urlParams.get('resumeOrder');
                if (resumeId) {
                    try {
                        const res = await fetch('/nokos/active-order/' + resumeId);
                        const data = await res.json();
                        if (data.success) {
                            this.selectedNokosProduct = { id: data.productId, name: data.productName };
                            this.activeTab = '<%= nokosCatId %>';
                            this.orderId = resumeId;
                            this.phoneNumber = data.phoneNumber;
                            this.showStatus = true;
                            this.otpCode = data.otpCode || '------';
                            this.otpReceived = data.status === 'completed';
                            
                            if (data.status === 'pending') {
                                this.startMonitoring();
                            }
                            window.uiCore.showToast('Melanjutkan pemantauan OTP...', 'info');
                        } else {
                            window.uiCore.showToast(data.message || 'Gagal memuat detail pesanan.', 'error');
                        }
                    } catch (e) {
                        console.error('Failed to resume order:', e);
                        window.uiCore.showToast('Gagal memulihkan sesi pesanan virtual.', 'error');
                    }
                }
            },

            async selectNokosProduct(product) {
                this.activeTab = '<%= nokosCatId %>';
                this.selectedNokosProduct = product;
                this.loadingCountries = true;
                this.nokosCountries = [];
                this.nokosSearch = '';
                this.selectedCountryName = '';
                this.showStatus = false;
                this.otpReceived = false;
                this.otpCode = '------';
                if (this.monitorInterval) {
                    clearInterval(this.monitorInterval);
                    this.monitorInterval = null;
                }

                try {
                    const res = await fetch('/nokos/countries/' + product.id);
                    const data = await res.json();
                    if (data.success) {
                        this.nokosCountries = data.countries;
                    } else {
                        window.uiCore.showToast(data.message || 'Gagal memuat negara.', 'error');
                        this.selectedNokosProduct = null;
                    }
                } catch (err) {
                    console.error(err);
                    window.uiCore.showToast('Gagal memuat daftar negara.', 'error');
                    this.selectedNokosProduct = null;
                } finally {
                    this.loadingCountries = false;
                }
            },

            get filteredNokosCountries() {
                if (!this.nokosSearch) return this.nokosCountries;
                return this.nokosCountries.filter(c => 
                    c.country_name.toLowerCase().includes(this.nokosSearch.toLowerCase())
                );
            },

            get uniqueNokosCountries() {
                const seen = new Set();
                const unique = [];
                this.nokosCountries.forEach(c => {
                    if (!seen.has(c.country_name)) {
                        seen.add(c.country_name);
                        unique.push(c);
                    }
                });
                return unique.sort((a, b) => a.country_name.localeCompare(b.country_name));
            },

            get operatorRatesForSelectedCountry() {
                if (!this.selectedCountryName) return [];
                const options = this.nokosCountries.filter(c => c.country_name === this.selectedCountryName);
                options.sort((a, b) => a.price - b.price);
                if (options.length === 0) return [];
                
                return options.map((opt, index) => {
                    let type = 'Standar';
                    if (options.length > 1) {
                        if (index === 0) type = 'Termurah';
                        else if (index === options.length - 1) type = 'Tertinggi / Premium';
                    }
                    return {
                        type,
                        ...opt
                    };
                });
            },
            getCountryCode(name) {
                if (!name) return 'id';
                const lower = name.toLowerCase();
                if (lower.includes('indonesia')) return 'id';
                if (lower.includes('united states') || lower.includes('amerika')) return 'us';
                if (lower.includes('united kingdom') || lower.includes('inggris')) return 'gb';
                if (lower.includes('malaysia')) return 'my';
                if (lower.includes('russia') || lower.includes('rusia')) return 'ru';
                if (lower.includes('vietnam')) return 'vn';
                if (lower.includes('thailand')) return 'th';
                if (lower.includes('philippines') || lower.includes('filipina')) return 'ph';
                if (lower.includes('singapore') || lower.includes('singapura')) return 'sg';
                if (lower.includes('india')) return 'in';
                if (lower.includes('brazil')) return 'br';
                if (lower.includes('cambodia') || lower.includes('kamboja')) return 'kh';
                if (lower.includes('myanmar')) return 'mm';
                
                const country = this.nokosCountries.find(c => c.country_name === name);
                if (country && country.country_emoji) {
                    const emoji = country.country_emoji;
                    if (emoji && emoji.length >= 2) {
                        const codePoints = Array.from(emoji).map(c => c.codePointAt(0));
                        const chars = codePoints
                            .filter(cp => cp >= 127462 && cp <= 127487)
                            .map(cp => String.fromCharCode(cp - 127462 + 65));
                        if (chars.length > 0) return chars.join('').toLowerCase();
                    }
                }
                return 'id';
            },

            openPaymentModal(rate) {
                this.selectedRate = rate;
                this.showPaymentModal = true;
            },

            async processPayment(method) {
                if (this.loadingOrder || !this.selectedRate) return;
                this.showPaymentModal = false;
                this.loadingOrder = true;

                if (method === 'balance') {
                    try {
                        const response = await fetch('/nokos/order', {
                            method: 'POST',
                            headers: { 
                                'Content-Type': 'application/json',
                                'x-csrf-token': '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>'
                            },
                            body: JSON.stringify({
                                serviceId: this.selectedNokosProduct.id,
                                countryId: this.selectedRate.id
                            })
                        });
                        
                        let data;
                        try { data = await response.json(); } catch(err) { throw new Error('Server error'); }

                        if (data.success) {
                            this.orderId = data.orderId;
                            this.phoneNumber = data.phoneNumber;
                            this.showStatus = true;
                            window.uiCore.showToast('Nomor virtual berhasil disewa!', 'success');
                            
                            const balanceEl = document.querySelector('[data-balance-text]');
                            if (balanceEl) {
                                const current = Number(balanceEl.innerText.replace(/[^0-9]/g, '')) || 0;
                                balanceEl.innerText = 'Rp ' + (current - this.selectedRate.price).toLocaleString('id-ID');
                            }
                            this.startMonitoring();
                        } else {
                            window.uiCore.showToast(data.message || 'Gagal memesan nomor.', 'error');
                        }
                    } catch (e) {
                        console.error(e);
                        window.uiCore.showToast('Kesalahan koneksi server.', 'error');
                    } finally {
                        this.loadingOrder = false;
                    }
                } else if (method === 'qris') {
                    try {
                        const response = await fetch('/nokos/qris-order', {
                            method: 'POST',
                            headers: { 
                                'Content-Type': 'application/json',
                                'x-csrf-token': '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>'
                            },
                            body: JSON.stringify({
                                serviceId: this.selectedNokosProduct.id,
                                countryId: this.selectedRate.id
                            })
                        });
                        let data;
                        try { data = await response.json(); } catch(err) { throw new Error('Server error'); }
                        
                        if (data.success) {
                            this.qrisString = data.qrString;
                            this.qrisOrderId = data.orderId;
                            this.showQrisModal = true;
                            this.startQrisPolling();
                        } else {
                            window.uiCore.showToast(data.message || 'Gagal memuat QRIS.', 'error');
                        }
                    } catch (e) {
                        console.error(e);
                        window.uiCore.showToast('Kesalahan membuat QRIS.', 'error');
                    } finally {
                        this.loadingOrder = false;
                    }
                }
            },

            startQrisPolling() {
                if (this.qrisInterval) clearInterval(this.qrisInterval);
                this.qrisInterval = setInterval(async () => {
                    try {
                        const res = await fetch('/nokos/qris-status/' + this.qrisOrderId);
                        const data = await res.json();
                        
                        if (data.status === 'completed') {
                            clearInterval(this.qrisInterval);
                            this.showQrisModal = false;
                            
                            this.orderId = data.orderId || this.qrisOrderId;
                            this.phoneNumber = data.phoneNumber;
                            this.showStatus = true;
                            window.uiCore.showToast('Pembayaran QRIS Lunas! Nomor berhasil didapat.', 'success');
                            this.startMonitoring();
                        } else if (data.status === 'failed') {
                            clearInterval(this.qrisInterval);
                            this.showQrisModal = false;
                            window.uiCore.showToast(data.message || 'Transaksi gagal atau stok habis, saldo Anda telah dikembalikan.', 'error');
                        }
                    } catch (e) {
                        console.error('QRIS Polling Error:', e);
                    }
                }, 5000);
            },

            startMonitoring() {
                if (this.monitorInterval) clearInterval(this.monitorInterval);
                this.monitorInterval = setInterval(async () => {
                    try {
                        const res = await fetch('/nokos/status/' + this.orderId);
                        const data = await res.json();
                        if (data.success) {
                            if (data.status === 'completed') {
                                this.otpCode = data.otpCode;
                                this.otpReceived = true;
                                clearInterval(this.monitorInterval);
                                this.monitorInterval = null;
                                window.uiCore.showToast('SMS OTP Berhasil Diterima!', 'success');
                            } else if (data.status === 'failed') {
                                clearInterval(this.monitorInterval);
                                this.monitorInterval = null;
                                window.uiCore.showToast('Order kadaluwarsa / dibatalkan.', 'error');
                                this.resetCheckout();
                            }
                        }
                    } catch (e) {
                        console.error('Monitoring error:', e);
                    }
                }, 5000);
            },

            resetCheckout() {
                this.selectedNokosProduct = null;
                this.showStatus = false;
                this.otpReceived = false;
                this.otpCode = '------';
                if (this.monitorInterval) {
                    clearInterval(this.monitorInterval);
                    this.monitorInterval = null;
                }
            },

            copyPhone() {
                navigator.clipboard.writeText(this.phoneNumber);
                window.uiCore.showToast('Nomor virtual berhasil disalin!', 'success');
            },

            copyOtp() {
                navigator.clipboard.writeText(this.otpCode);
                window.uiCore.showToast('Kode OTP berhasil disalin!', 'success');
            }
        }">

            <!-- Normal View Container (Products and Categories) - Always Visible -->
            <div class="space-y-6 sm:space-y-8">
                <!-- Header and Filter controls in a modern cluster layout -->
                <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-6 pb-6 border-b border-slate-200/50 dark:border-slate-800/50">
                    
                <div data-aos="fade-right">
                    <a href="/dashboard/marketplace" class="inline-flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-blue-500 mb-4 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                        Kembali ke Hub
                    </a>
                    <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight"><%= title %></h1>
    
                        <p class="text-sm font-medium text-slate-500 mt-1"><%= pageSubtitle %></p>
                    </div>
                    
                    <div class="flex flex-col md:flex-row gap-4 items-stretch md:items-center">
                        <% if (!requestedType) { %>
                        <!-- Category Tabs with elegant flex wrap grid -->
                        <div class="flex flex-wrap bg-white dark:bg-[#12121A] p-1.5 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm max-w-full gap-1.5" data-aos="fade-left">
                            <button @click="activeTab = 'all'; activeNode = 'all'" :class="activeTab === 'all' ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'text-slate-500 hover:text-slate-900 dark:hover:text-white'" class="px-5 py-2.5 rounded-xl text-xs font-black transition-all whitespace-nowrap uppercase tracking-wider">
                                Semua Produk
                            </button>
                            <% categories.forEach(cat => { %>
                                <button @click="activeTab = '<%= cat.id %>'; activeNode = 'all'" :class="activeTab === '<%= cat.id %>' ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'text-slate-500 hover:text-slate-900 dark:hover:text-white'" class="px-5 py-2.5 rounded-xl text-xs font-black transition-all whitespace-nowrap uppercase tracking-wider">
                                    <%= cat.name %>
                                </button>
                            <% }) %>
                            
                            <% if (!nokosCategory && nokosProducts.length > 0) { %>
                                <button @click="activeTab = '<%= nokosCatId %>'; activeNode = 'all'" :class="activeTab === '<%= nokosCatId %>' ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'text-slate-500 hover:text-slate-900 dark:hover:text-white'" class="px-5 py-2.5 rounded-xl text-xs font-black transition-all whitespace-nowrap uppercase tracking-wider">
                                    Nokos / OTP
                                </button>
                            <% } %>
                        </div>
                        <% } %>

                        <!-- Modern Search Bar -->
                        <div class="relative min-w-[240px]" data-aos="fade-left" data-aos-delay="100">
                            <input type="text" x-model="searchQuery" placeholder="Cari layanan..." class="w-full bg-white dark:bg-[#12121A] border border-slate-200 dark:border-slate-800 rounded-xl px-5 py-3 pl-11 text-xs font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all duration-300">
                            <svg class="w-4 h-4 absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </div>
                    </div>
                </div>

                <% 
                  const pteroCategories = categories.filter(c => c.type === 'pterodactyl');
                  const pteroCatIds = pteroCategories.map(c => c.id);
                  const pteroNodes = [];
                  const seenNodeIds = new Set();
                  products.forEach(p => {
                      if (p.pteroNode && !seenNodeIds.has(p.pteroNode.id)) {
                          seenNodeIds.add(p.pteroNode.id);
                          pteroNodes.push(p.pteroNode);
                      }
                  });
                %>

                <!-- Node Filter Panel -->
                <% if (pteroNodes.length > 0) { %>
                    <div x-show="[<%= pteroCatIds.map(id => `'${id}'`).join(',') %>].includes(activeTab)"
                         x-transition:enter="transition ease-out duration-300"
                         x-transition:enter-start="opacity-0 -translate-y-3"
                         x-transition:enter-end="opacity-100 translate-y-0"
                         x-transition:leave="transition ease-in duration-200"
                         x-transition:leave-start="opacity-100 translate-y-0"
                         x-transition:leave-end="opacity-0 -translate-y-3"
                         class="p-6 bg-white dark:bg-[#12121A] rounded-[2rem] border border-slate-200 dark:border-slate-800 shadow-sm transition-colors relative overflow-hidden"
                         x-cloak
                     >
                         <div class="absolute top-0 left-0 w-1.5 h-full bg-blue-600"></div>
                         <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 mb-2 uppercase tracking-widest">Region Node</span>
                         <p class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-4 ml-0.5">Filter Berdasarkan Lokasi / Spesifikasi Node:</p>
                         <div class="flex flex-wrap gap-2">
                             <button @click="activeNode = 'all'" 
                                     :class="activeNode === 'all' ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-700'" 
                                     class="px-4.5 py-2.5 rounded-xl text-xs font-black transition-all uppercase tracking-wider active:scale-95"
                             >
                                 Semua Lokasi
                             </button>
                             <% pteroNodes.forEach(node => { %>
                                 <button @click="activeNode = '<%= node.id %>'" 
                                         :class="activeNode === '<%= node.id %>' ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-700'" 
                                         class="px-4.5 py-2.5 rounded-xl text-xs font-black transition-all uppercase tracking-wider active:scale-95 flex items-center gap-1.5"
                                 >
                                     <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                                     <%= node.name %> [<%= node.location || 'ID' %>]
                                 </button>
                             <% }) %>
                         </div>
                     </div>
                 <% } %>
       
                 <!-- Products Grid (Hidden for Nokos and SMM category to load unified block instead) -->
                 <div x-show="activeTab !== '<%= nokosCatId %>' && activeTab !== '<%= smmCatId %>'" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                     <% products.forEach(product => { %>
                         <div x-show="((activeTab === 'all' && '<%= product.category ? product.category.type : '' %>' !== 'otp' && '<%= product.category ? product.category.type : '' %>' !== 'smm') || activeTab === '<%= product.category ? product.category.id : 'other' %>') && 
                                     (activeNode === 'all' || '<%= product.pteroNodeId || (product.pteroNode ? product.pteroNode.id : null) %>' === activeNode) && 
                                     ('<%= product.name %>'.toLowerCase().includes(searchQuery.toLowerCase()))"  
                             x-transition:enter="transition ease-out duration-300"
                             x-transition:enter-start="opacity-0 translate-y-4 scale-98"
                             x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                             class="h-full"
                        >
                            <%- include('../partials/product-card', { product, isDashboard: true }) %>
                        </div>
                    <% }) %>
                 </div>

                     <!-- Dynamic Service Platform Switcher — Premium Dropdown -->
                     <div x-show="activeTab === '<%= nokosCatId %>'" x-cloak class="w-full">
                         <% if (nokosProducts.length === 0) { %>
                             <div class="py-20 flex flex-col items-center justify-center text-center bg-white dark:bg-[#12121A] rounded-[3rem] border-2 border-dashed border-slate-200 dark:border-slate-800 shadow-sm transition-colors mt-6">
                                 <div class="w-20 h-20 bg-slate-100 dark:bg-slate-800/50 rounded-3xl flex items-center justify-center mx-auto mb-6 text-slate-400 dark:text-slate-500">
                                     <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                 </div>
                                 <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">Layanan OTP Tidak Tersedia</h3>
                                 <p class="text-sm text-slate-500 dark:text-slate-400 max-w-md mx-auto">Saat ini layanan OTP / Nomor Virtual sedang dinonaktifkan atau kosong. Silakan periksa kembali nanti.</p>
                             </div>
                         <% } else { %>
                             <div class="relative bg-gradient-to-br from-white to-slate-50/80 dark:from-[#0E1626] dark:to-[#0B0E1A] rounded-[2.5rem] p-6 sm:p-8 border border-slate-200/80 dark:border-white/5 shadow-2xl shadow-blue-900/10 overflow-hidden group"
                          x-data="{
                            serviceOpen: false,
                            serviceSearch: ''
                          }"
                          @keydown.escape="serviceOpen = false"
                          @click.away="serviceOpen = false"
                     >
                         <!-- Ambient glow -->
                         <div class="absolute -top-24 -right-24 w-64 h-64 bg-blue-500/15 blur-[100px] rounded-full pointer-events-none"></div>
                         <div class="absolute -bottom-20 -left-20 w-48 h-48 bg-indigo-500/10 blur-[80px] rounded-full pointer-events-none"></div>

                         <div class="relative z-10">
                             <!-- Header -->
                             <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-7">
                                 <div>
                                     <div class="inline-flex items-center gap-1.5 py-1 px-3 rounded-full text-[10px] font-black bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 uppercase tracking-wider mb-3">
                                         <span class="relative flex h-2 w-2 mr-0.5">
                                             <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                                             <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
                                         </span>
                                         Virtual OTP Platform
                                     </div>
                                     <h2 class="text-2xl sm:text-3xl font-black text-slate-900 dark:text-white tracking-tight">Layanan Virtual OTP</h2>
                                     <p class="text-sm text-slate-500 dark:text-slate-400 font-medium mt-1.5">Pilih platform OTP untuk melihat daftar negara dan rate real-time.</p>
                                 </div>
                             </div>

                             <!-- Service Dropdown + Selected Preview -->
                             <div class="flex flex-col sm:flex-row gap-4 items-stretch sm:items-start">
                                 <!-- Dropdown Trigger + Menu -->
                                 <div class="relative flex-1">
                                     <label class="block text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-2">Pilih Platform / Layanan</label>

                                     <!-- Trigger Button -->
                                     <button type="button"
                                             @click="serviceOpen = !serviceOpen; serviceSearch = ''; $nextTick(() => $refs.serviceSearchInput && $refs.serviceSearchInput.focus())"
