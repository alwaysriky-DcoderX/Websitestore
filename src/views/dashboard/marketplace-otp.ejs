                                             :class="serviceOpen ? 'border-blue-500/60 ring-2 ring-blue-500/20' : 'border-slate-200 dark:border-white/5 hover:border-blue-400/50'"
                                     >
                                         <div class="flex items-center gap-3 min-w-0">
                                             <template x-if="!selectedNokosProduct">
                                                 <div class="flex items-center gap-3">
                                                     <div class="w-9 h-9 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center shrink-0">
                                                         <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                                     </div>
                                                     <span class="text-sm font-bold text-slate-400 dark:text-slate-500">-- Pilih Layanan OTP --</span>
                                                 </div>
                                             </template>
                                             <template x-if="selectedNokosProduct">
                                                 <div class="flex items-center gap-3 min-w-0">
                                                     <div class="w-9 h-9 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-600/30">
                                                         <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                                                     </div>
                                                     <div class="min-w-0">
                                                         <p class="text-sm font-black text-slate-900 dark:text-white truncate" x-text="selectedNokosProduct.name"></p>
                                                         <p class="text-[10px] text-blue-500 font-black uppercase tracking-widest">Aktif</p>
                                                     </div>
                                                 </div>
                                             </template>
                                         </div>
                                         <svg class="w-5 h-5 text-slate-400 shrink-0 transition-transform duration-300" :class="serviceOpen ? 'rotate-180 text-blue-500' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
                                         </svg>
                                     </button>

                                     <!-- Dropdown Panel -->
                                     <div x-show="serviceOpen"
                                          x-transition:enter="transition ease-out duration-200"
                                          x-transition:enter-start="opacity-0 translate-y-2 scale-[0.98]"
                                          x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                                          x-transition:leave="transition ease-in duration-150"
                                          x-transition:leave-start="opacity-100"
                                          x-transition:leave-end="opacity-0 translate-y-1"
                                          class="absolute left-0 right-0 z-50 mt-2 bg-white dark:bg-[#13182B] border border-slate-200 dark:border-white/10 rounded-2xl shadow-2xl shadow-slate-900/20 overflow-hidden"
                                          x-cloak
                                     >
                                         <!-- Search Bar inside dropdown -->
                                         <div class="p-3 border-b border-slate-100 dark:border-white/5">
                                             <div class="relative">
                                                 <input type="text"
                                                        x-ref="serviceSearchInput"
                                                        x-model="serviceSearch"
                                                        placeholder="Cari layanan..."
                                                        class="w-full bg-slate-50 dark:bg-[#181C2A] border border-slate-200 dark:border-white/5 rounded-xl px-4 py-3 pl-10 text-sm font-bold focus:ring-2 focus:ring-blue-500/40 focus:outline-none transition-all text-slate-900 dark:text-white placeholder-slate-400"
                                                 >
                                                 <svg class="w-4 h-4 absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                             </div>
                                         </div>
                                         <!-- Options List -->
                                         <div class="max-h-[320px] overflow-y-auto p-2">
                                             <% nokosProducts.forEach(product => { %>
                                                 <button type="button"
                                                         x-show="'<%= product.name %>'.toLowerCase().includes(serviceSearch.toLowerCase())"
                                                         @click="selectNokosProduct({ id: '<%= product.id %>', name: '<%= product.name %>' }); serviceOpen = false; serviceSearch = ''"
                                                         class="w-full flex items-center gap-3 px-4 py-3.5 rounded-xl transition-all duration-150 text-left group/opt"
                                                         :class="selectedNokosProduct && selectedNokosProduct.id === '<%= product.id %>' ? 'bg-blue-600 text-white' : 'hover:bg-slate-50 dark:hover:bg-white/5 text-slate-800 dark:text-slate-200'"
                                                 >
                                                     <!-- Icon -->
                                                     <div class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0 transition-all"
                                                          :class="selectedNokosProduct && selectedNokosProduct.id === '<%= product.id %>' ? 'bg-white/20' : 'bg-slate-100 dark:bg-white/5 group-hover/opt:bg-blue-50 dark:group-hover/opt:bg-blue-500/10'"
                                                     >
                                                         <% if (product.name.toLowerCase().includes('whatsapp')) { %>
                                                             <svg class="w-5 h-5" :class="selectedNokosProduct && selectedNokosProduct.id === '<%= product.id %>' ? 'text-white' : 'text-[#25D366]'" viewBox="0 0 24 24" fill="currentColor"><path d="M12.004 2C6.48 2 2 6.48 2 12c0 1.73.44 3.36 1.21 4.79L2 22l5.37-1.39c1.4.74 2.99 1.16 4.63 1.16 5.52 0 10-4.48 10-10S17.52 2 12.004 2zm5.72 14.15c-.24.68-1.2 1.24-1.65 1.29-.41.05-.95.07-1.54-.12-.36-.12-.83-.28-1.42-.53-2.52-1.07-4.14-3.66-4.26-3.82-.12-.16-1.02-1.37-1.02-2.61s.64-1.85.87-2.1c.24-.24.52-.3.69-.3.17 0 .34 0 .49.01.16.01.37-.06.58.45.21.52.73 1.79.79 1.91.06.12.1.26.02.42-.08.16-.18.26-.29.4-.12.13-.25.3-.36.42-.12.14-.25.29-.1.54.14.24.64 1.07 1.38 1.73.95.85 1.74 1.11 1.99 1.23.25.12.39.1.53-.06.14-.16.6-1.04.76-1.25.16-.21.32-.18.54-.1.22.08 1.4.66 1.64.78.24.12.4.18.46.28.06.1.06.58-.18 1.26z"/></svg>
                                                         <% } else if (product.name.toLowerCase().includes('telegram')) { %>
                                                             <svg class="w-5 h-5" :class="selectedNokosProduct && selectedNokosProduct.id === '<%= product.id %>' ? 'text-white' : 'text-[#0088cc]'" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.12.89-.52 3.24-.73 4.37-.09.48-.27.64-.44.66-.37.03-.65-.25-.97-.46-.5-.33-.78-.53-1.26-.85-.56-.37-.2-.58.12-.91.08-.09 1.54-1.41 1.57-1.54.01-.02.01-.1-.04-.15-.05-.05-.12-.03-.17-.02-.07.01-1.22.77-3.44 2.27-.33.22-.62.33-.88.33-.29-.01-.84-.17-1.25-.3-.5-.17-.9-.26-.86-.55.02-.15.22-.3.6-.46 2.34-1.02 3.9-1.7 4.67-2.03 2.23-.93 2.69-1.09 2.99-1.1.07 0 .22.02.32.1.08.07.11.16.12.23 0 .04.01.12 0 .19z"/></svg>
                                                         <% } else if (product.name.toLowerCase().includes('google')) { %>
                                                             <svg class="w-5 h-5 bg-white rounded-full p-[2px]" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.77c-.98.66-2.23 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.85z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.85c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                                                         <% } else { %>
                                                             <svg class="w-5 h-5" :class="selectedNokosProduct && selectedNokosProduct.id === '<%= product.id %>' ? 'text-white' : 'text-slate-400'" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                                         <% } %>
                                                     </div>
                                                     <!-- Text -->
                                                     <div class="flex-1 min-w-0">
                                                         <p class="text-sm font-black truncate"><%= product.name %></p>
                                                         <p class="text-[10px] font-bold mt-0.5"
                                                            :class="selectedNokosProduct && selectedNokosProduct.id === '<%= product.id %>' ? 'text-white/70' : 'text-slate-400'">
                                                             Mulai dari Rp <%= ((product.price || 0) + (product.otpMargin || 0)).toLocaleString('id-ID') %>
                                                         </p>
                                                     </div>
                                                     <!-- Checkmark if selected -->
                                                     <template x-if="selectedNokosProduct && selectedNokosProduct.id === '<%= product.id %>'">
                                                         <svg class="w-4 h-4 text-white shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                                                     </template>
                                                 </button>
                                             <% }) %>
                                             <!-- Empty state -->
                                             <% if (nokosProducts.length === 0) { %>
                                             <div x-show="serviceSearch"
                                             <% } else { %>
                                             <div x-show="serviceSearch && !<%= nokosProducts.map(p => `'${p.name.replace(/'/g, "\\\\'")}'.toLowerCase().includes(serviceSearch.toLowerCase())`).join(' && !') %>"
                                             <% } %>
                                                  class="py-8 text-center">
                                                 <p class="text-xs font-bold text-slate-400">Layanan tidak ditemukan 🔍</p>
                                             </div>
                                         </div>
                                     </div>
                                 </div>

                                 <!-- Quick platform pills (mobile-friendly horizontal scroll) -->
                                 <div class="sm:w-auto">
                                     <label class="block text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-2">Populer</label>
                                     <div class="flex gap-2 flex-wrap sm:flex-col">
                                         <% nokosProducts.slice(0, 4).forEach(product => { %>
                                             <button type="button"
                                                     @click="selectNokosProduct({ id: '<%= product.id %>', name: '<%= product.name %>' })"
                                                     class="flex items-center gap-2 px-3 py-2.5 rounded-xl border-2 transition-all duration-200 text-xs font-black whitespace-nowrap active:scale-95"
                                                     :class="selectedNokosProduct && selectedNokosProduct.id === '<%= product.id %>'
                                                         ? 'border-blue-500 bg-blue-600 text-white shadow-lg shadow-blue-600/20'
                                                         : 'border-slate-200 dark:border-white/5 bg-white/70 dark:bg-white/3 text-slate-600 dark:text-slate-400 hover:border-blue-400/50 hover:bg-blue-50 dark:hover:bg-blue-500/10 hover:text-blue-600'"
                                             >
                                                 <% if (product.name.toLowerCase().includes('whatsapp')) { %>
                                                     <svg class="w-4 h-4 shrink-0" :class="selectedNokosProduct && selectedNokosProduct.id === '<%= product.id %>' ? 'text-white' : 'text-[#25D366]'" viewBox="0 0 24 24" fill="currentColor"><path d="M12.004 2C6.48 2 2 6.48 2 12c0 1.73.44 3.36 1.21 4.79L2 22l5.37-1.39c1.4.74 2.99 1.16 4.63 1.16 5.52 0 10-4.48 10-10S17.52 2 12.004 2z"/></svg>
                                                 <% } else if (product.name.toLowerCase().includes('telegram')) { %>
                                                     <svg class="w-4 h-4 shrink-0" :class="selectedNokosProduct && selectedNokosProduct.id === '<%= product.id %>' ? 'text-white' : 'text-[#0088cc]'" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
                                                 <% } else if (product.name.toLowerCase().includes('google')) { %>
                                                     <svg class="w-4 h-4 shrink-0 bg-white rounded-full p-[2px]" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.77c-.98.66-2.23 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.85z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.85c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                                                 <% } else { %>
                                                     <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                                 <% } %>
                                                 <span><%= product.name.split(' ')[0] %></span>
                                             </button>
                                         <% }) %>
                                     </div>
                                 </div>
                             </div>

                             <!-- Empty prompt when nothing selected -->
                             <div x-show="!selectedNokosProduct"
                                  class="mt-6 py-8 border-2 border-dashed border-slate-200 dark:border-white/5 rounded-2xl flex flex-col items-center gap-3 text-center"
                                  x-cloak
                             >
                                 <div class="w-14 h-14 rounded-2xl bg-slate-100 dark:bg-white/5 flex items-center justify-center">
                                     <svg class="w-7 h-7 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                 </div>
                                 <div>
                                     <p class="text-sm font-black text-slate-600 dark:text-slate-300">Belum Ada Platform Dipilih</p>
                                     <p class="text-xs text-slate-400 mt-1">Pilih dari dropdown di atas atau klik tombol populer</p>
                                 </div>
                             </div>
                         </div>
                     </div>

                     <!-- Dynamic Inline Country Picker -->
                      <div x-show="selectedNokosProduct !== null && !showStatus" 
                           x-transition:enter="transition ease-out duration-300"
                           x-transition:enter-start="opacity-0 translate-y-4"
                           x-transition:enter-end="opacity-100 translate-y-0"
                           class="bg-white dark:bg-[#12121A] rounded-[2.2rem] p-6 sm:p-8 border border-slate-200/80 dark:border-slate-800/80 shadow-xl space-y-6"
                           x-cloak
                      >
                          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pb-5 border-b border-slate-100 dark:border-slate-850/60">
                              <div>
                                  <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 uppercase tracking-widest mb-1.5" x-text="selectedNokosProduct ? selectedNokosProduct.name : ''"></span>
                                  <h3 class="text-lg font-black text-slate-900 dark:text-white leading-tight">Pilih Negara & Operator Rate</h3>
                              </div>
                          </div>

                          <!-- Live Loader -->
                          <div x-show="loadingCountries" class="py-16 flex flex-col items-center justify-center gap-3">
                              <svg class="animate-spin h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                              <p class="text-xs text-slate-400 font-bold">Menghubungi server virtual number...</p>
                          </div>

                          <!-- Country Dropdown Selector (Only shown when not loading and we have countries available) -->
                          <div x-show="!loadingCountries && nokosCountries.length > 0" class="space-y-6">
                              <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 py-4 px-4 bg-slate-50 dark:bg-slate-900/50 rounded-2.5xl border border-slate-150 dark:border-slate-800/80">
                                  <div class="flex-1 relative" x-data="{ open: false, search: '' }" @click.away="open = false">
                                      <label class="block text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1.5">Pilih Negara Asal Nomor</label>
                                      
                                      <!-- Custom Dropdown Trigger -->
                                      <div @click="open = !open; search = ''" 
                                           class="w-full bg-white dark:bg-[#181824] border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3.5 flex items-center justify-between cursor-pointer shadow-sm hover:border-blue-500/50 dark:hover:border-blue-500/30 transition-all select-none"
                                      >
                                          <div class="flex items-center gap-3">
                                              <template x-if="selectedCountryName">
                                                  <div class="flex items-center gap-2.5">
                                                      <img :src="'https://flagcdn.com/w40/' + getCountryCode(selectedCountryName) + '.png'" 
                                                           @error="$el.src = 'https://flagcdn.com/w40/un.png'"
                                                           class="w-5.5 h-4 rounded shadow-sm object-cover shrink-0">
                                                      <span class="text-xs font-black text-slate-800 dark:text-slate-100" x-text="selectedCountryName"></span>
                                                  </div>
                                              </template>
                                              <template x-if="!selectedCountryName">
                                                  <span class="text-xs font-bold text-slate-400 dark:text-slate-500">-- Silakan Pilih Negara Asal --</span>
                                              </template>
                                          </div>
                                          
                                          <svg class="w-4 h-4 text-slate-400 transition-transform duration-200" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
                                          </svg>
                                      </div>

                                      <!-- Custom Dropdown Menu -->
                                      <div x-show="open" 
                                           x-transition:enter="transition ease-out duration-150"
                                           x-transition:enter-start="opacity-0 translate-y-2"
                                           x-transition:enter-end="opacity-100 translate-y-0"
                                           class="absolute left-0 right-0 z-50 mt-2 bg-white dark:bg-[#181824] border border-slate-200 dark:border-slate-800 rounded-2xl shadow-2xl p-3 space-y-2.5 max-h-[280px] flex flex-col"
                                           x-cloak
                                      >
                                          <!-- Dropdown Search -->
                                          <div class="relative shrink-0">
                                              <input type="text" 
                                                     x-model="search" 
                                                     placeholder="Cari negara..." 
                                                     class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 pl-9 text-xs font-bold focus:ring-2 focus:ring-blue-500 focus:outline-none transition-all text-slate-800 dark:text-white placeholder-slate-400"
                                              >
                                              <svg class="w-3.5 h-3.5 absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                              </svg>
                                          </div>

                                          <!-- Dropdown List Items -->
                                          <div class="flex-1 overflow-y-auto pr-1 space-y-1 select-none no-scrollbar">
                                              <template x-for="c in uniqueNokosCountries.filter(item => item.country_name.toLowerCase().includes(search.toLowerCase()))" :key="c.country_name">
                                                  <div @click="selectedCountryName = c.country_name; open = false;" 
                                                       class="flex items-center justify-between px-3 py-2.5 rounded-xl cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-900/60 transition-colors"
                                                  >
                                                      <div class="flex items-center gap-3">
                                                          <img :src="'https://flagcdn.com/w40/' + getCountryCode(c.country_name) + '.png'" 
                                                               @error="$el.src = 'https://flagcdn.com/w40/un.png'"
                                                               class="w-5.5 h-4 rounded shadow-sm object-cover shrink-0">
                                                          <span class="text-xs font-black text-slate-800 dark:text-slate-100" x-text="c.country_name"></span>
                                                      </div>
                                                      
                                                      <span class="text-[9px] font-black uppercase tracking-wider bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 px-2 py-0.5 rounded-full" x-text="c.available + ' Pcs'"></span>
                                                  </div>
                                              </template>
                                              
                                              <div x-show="uniqueNokosCountries.filter(item => item.country_name.toLowerCase().includes(search.toLowerCase())).length === 0" 
                                                   class="text-center py-6 text-xs font-bold text-slate-400"
                                              >
                                                  Negara tidak ditemukan...
                                              </div>
                                          </div>
                                      </div>
                                  </div>
                              </div>

                              <!-- Rate Options Tiers Display (Cheapest, Standard, Premium) -->
                              <div x-show="selectedCountryName !== ''" class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-4" x-transition>
                                  <template x-for="rate in operatorRatesForSelectedCountry" :key="rate.id">
                                      <div class="relative overflow-hidden bg-slate-50 dark:bg-slate-900 border-2 rounded-[2rem] p-6 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between"
