                                              <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border"
                                                    :class="rate.type === 'Termurah' 
                                                              ? 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border-emerald-500/20' 
                                                              : rate.type === 'Tertinggi / Premium' 
                                                                ? 'bg-violet-500/10 text-violet-600 dark:text-violet-400 border-violet-500/20 pulse-glow' 
                                                                : 'bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-500/20'"
                                                    x-text="rate.type"
                                              ></span>
                                              
                                              <span class="text-xs font-bold text-slate-400 dark:text-slate-500" x-text="'Stok: ' + rate.available + ' pcs'"></span>
                                          </div>

                                          <!-- Card Info -->
                                          <div class="mb-5">
                                              <div class="flex items-center gap-2 mb-1">
                                                  <span class="text-3xl" x-text="rate.country_emoji"></span>
                                                  <h4 class="font-black text-slate-900 dark:text-white tracking-tight text-sm" x-text="rate.country_name"></h4>
                                              </div>
                                              <p class="text-[10px] text-slate-400 dark:text-slate-500 font-medium">Layanan virtual number dengan stok terverifikasi.</p>
                                          </div>

                                          <!-- Price & Action Button -->
                                          <div class="pt-5 border-t border-slate-200/60 dark:border-slate-800/60 flex items-center justify-between gap-4 mt-auto">
                                              <div>
                                                  <p class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-0.5">Total Harga</p>
                                                  <p class="font-black text-base text-slate-900 dark:text-white" x-text="'Rp ' + Number(rate.price).toLocaleString('id-ID')"></p>
                                              </div>
                                              
                                              <button @click="openPaymentModal(rate)"
                                                      class="py-3 px-5 rounded-xl font-black text-xs transition-all duration-300 active:scale-95 shadow-md flex items-center gap-1.5"
                                                      :class="rate.type === 'Termurah' 
                                                                ? 'bg-emerald-600 hover:bg-emerald-500 text-white shadow-emerald-600/10 hover:shadow-emerald-500/30' 
                                                                : rate.type === 'Tertinggi / Premium' 
                                                                  ? 'bg-violet-600 hover:bg-violet-500 text-white shadow-violet-600/10 hover:shadow-violet-500/30' 
                                                                  : 'bg-slate-900 dark:bg-white text-white dark:text-slate-900 hover:bg-blue-600 dark:hover:bg-blue-600 hover:text-white dark:hover:text-white shadow-black/5 hover:shadow-blue-600/25'"
                                              >
                                                  <span>Sewa</span>
                                                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                                              </button>
                                          </div>
                                      </div>
                                  </template>
                              </div>

                              <!-- Empty Tier Prompt -->
                              <div x-show="selectedCountryName === ''" class="text-center py-10 bg-slate-50 dark:bg-slate-900/30 rounded-2xl border border-dashed border-slate-250 dark:border-slate-800">
                                  <p class="text-xs font-bold text-slate-400">Silakan pilih salah satu negara dari dropdown di atas untuk memuat penawaran harga.</p>
                              </div>
                          </div>

                          <!-- Empty country state -->
                          <div x-show="!loadingCountries && nokosCountries.length === 0" class="text-center py-10">
                              <p class="text-xs font-bold text-slate-400">Layanan sedang kosong atau tidak tersedia saat ini.</p>
                          </div>
                      </div>

                     <!-- Dynamic Inline Active OTP Monitoring Console -->
                     <div x-show="selectedNokosProduct !== null && showStatus" 
                          x-transition:enter="transition ease-out duration-500"
                          x-transition:enter-start="opacity-0 translate-y-8 scale-95"
                          x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                          class="bg-gradient-to-br from-slate-900 via-[#0B101E] to-[#0A0C14] rounded-[2.5rem] p-8 sm:p-10 border border-slate-800 text-white shadow-2xl shadow-blue-900/20 space-y-8 relative overflow-hidden group"
                          x-cloak
                     >
                         <!-- Dynamic glow decorations -->
                         <div class="absolute -top-32 -left-32 w-64 h-64 bg-blue-600/20 blur-[100px] rounded-full pointer-events-none transition-all duration-1000" :class="otpReceived ? 'bg-emerald-500/20' : 'bg-blue-600/20'"></div>
                         <div class="absolute bottom-0 right-0 w-64 h-64 bg-indigo-600/10 blur-[100px] rounded-full pointer-events-none"></div>

                         <!-- Header -->
                         <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 relative z-10">
                             <div class="flex items-center gap-5">
                                 <div :class="otpReceived ? 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30 shadow-[0_0_30px_rgba(16,185,129,0.3)]' : 'bg-blue-500/20 text-blue-400 border-blue-500/30 shadow-[0_0_30px_rgba(59,130,246,0.3)] pulse-glow'" class="w-16 h-16 rounded-[1.25rem] flex items-center justify-center text-3xl border shrink-0 transition-all duration-500">
                                     <span x-text="otpReceived ? '✅' : '⏳'"></span>
                                 </div>
                                 <div>
                                     <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/5 text-white rounded-full text-[9px] font-black uppercase tracking-widest border border-white/10 mb-2 backdrop-blur-md shadow-sm">
                                         <span :class="otpReceived ? 'bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.8)]' : 'bg-blue-500 animate-ping shadow-[0_0_10px_rgba(59,130,246,0.8)]'" class="w-2 h-2 rounded-full inline-block mr-1"></span>
                                         <span x-text="otpReceived ? 'OTP Berhasil Diterima' : 'Menunggu Pesan Masuk'"></span>
                                     </span>
                                     <h3 class="text-2xl font-black tracking-tight drop-shadow-md" x-text="selectedNokosProduct ? selectedNokosProduct.name : ''"></h3>
                                 </div>
                             </div>
                             
                             <div class="flex items-center gap-3 relative z-10">
                                 <button @click="cancelOrder()" x-show="!otpReceived" class="px-5 py-3 bg-red-500/10 hover:bg-red-500 text-red-400 hover:text-white border border-red-500/20 hover:border-red-500 rounded-xl font-black text-xs transition-all active:scale-95 shadow-lg shadow-red-500/5">
                                     Batalkan Sewa
                                 </button>
                                 <button @click="resetCheckout()" x-show="otpReceived" class="px-5 py-3 bg-gradient-to-r from-emerald-500 to-teal-400 hover:from-emerald-400 hover:to-teal-300 text-white rounded-xl font-black text-xs transition-all active:scale-95 shadow-xl shadow-emerald-500/20 flex items-center gap-2">
                                     <span>Selesai / Sewa Lagi</span>
                                     <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
                                 </button>
                             </div>
                         </div>

                         <!-- Monitor values -->
                         <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10">
                             <!-- Number box -->
                             <div class="bg-[#181C2A]/80 backdrop-blur-xl rounded-3xl p-6 md:p-8 border border-white/5 flex flex-col justify-between hover:border-blue-500/30 transition-colors group/card">
                                 <div>
                                     <div class="flex items-center justify-between mb-2">
                                         <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest">Virtual Phone Number</p>
                                         <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-slate-400 group-hover/card:text-blue-400 transition-colors">
                                             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                         </div>
                                     </div>
                                     <h4 class="text-3xl sm:text-4xl font-black tracking-wider text-white font-mono select-all drop-shadow-md" x-text="phoneNumber"></h4>
                                 </div>
                                 <div class="flex items-center gap-3 mt-8">
                                     <button @click="copyPhone()" class="flex-1 py-3.5 bg-blue-600 hover:bg-blue-500 text-white rounded-xl font-black text-xs transition-all flex items-center justify-center gap-2 active:scale-95 shadow-lg shadow-blue-600/20">
                                         <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path></svg>
                                         <span>Salin Nomor</span>
                                     </button>
                                     <a :href="'https://wa.me/' + phoneNumber.replace(/[^0-9]/g, '')" target="_blank" class="w-12 h-12 bg-emerald-500/10 hover:bg-emerald-500 text-emerald-500 hover:text-white border border-emerald-500/20 hover:border-emerald-500 rounded-xl flex items-center justify-center transition-all active:scale-95" title="Buka WhatsApp">
                                         <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12.004 2C6.48 2 2 6.48 2 12c0 1.73.44 3.36 1.21 4.79L2 22l5.37-1.39c1.4.74 2.99 1.16 4.63 1.16 5.52 0 10-4.48 10-10S17.52 2 12.004 2zm5.72 14.15c-.24.68-1.2 1.24-1.65 1.29-.41.05-.95.07-1.54-.12-.36-.12-.83-.28-1.42-.53-2.52-1.07-4.14-3.66-4.26-3.82-.12-.16-1.02-1.37-1.02-2.61s.64-1.85.87-2.1c.24-.24.52-.3.69-.3.17 0 .34 0 .49.01.16.01.37-.06.58.45.21.52.73 1.79.79 1.91.06.12.1.26.02.42-.08.16-.18.26-.29.4-.12.13-.25.3-.36.42-.12.14-.25.29-.1.54.14.24.64 1.07 1.38 1.73.95.85 1.74 1.11 1.99 1.23.25.12.39.1.53-.06.14-.16.6-1.04.76-1.25.16-.21.32-.18.54-.1.22.08 1.4.66 1.64.78.24.12.4.18.46.28.06.1.06.58-.18 1.26z"/></svg>
                                     </a>
                                 </div>
                             </div>
                             
                             <!-- SMS Code box -->
                             <div class="bg-[#181C2A]/80 backdrop-blur-xl rounded-3xl p-6 md:p-8 border border-white/5 flex flex-col justify-between hover:border-emerald-500/30 transition-colors group/card">
                                 <div>
                                     <div class="flex items-center justify-between mb-2">
                                         <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest">Pesan OTP SMS</p>
                                         <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-slate-400 group-hover/card:text-emerald-400 transition-colors">
                                             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                                         </div>
                                     </div>
                                     <h4 :class="otpReceived ? 'text-emerald-400 drop-shadow-[0_0_15px_rgba(16,185,129,0.5)]' : 'text-slate-600 font-mono opacity-50'" class="text-4xl sm:text-5xl font-black tracking-widest transition-all duration-500" x-text="otpCode"></h4>
                                 </div>
                                 <div class="flex items-center gap-3 mt-8">
                                     <button @click="copyOtp()" :disabled="!otpReceived" :class="otpReceived ? 'bg-emerald-600 hover:bg-emerald-500 text-white shadow-emerald-600/20 shadow-lg' : 'bg-white/5 text-white/30 cursor-not-allowed border border-white/10'" class="flex-1 py-3.5 rounded-xl font-black text-xs transition-all flex items-center justify-center gap-2 active:scale-95">
                                         <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path></svg>
                                         <span>Salin Kode OTP</span>
                                     </button>
                                 </div>
                             </div>
                         </div>

                         <!-- Live status block with animated loading bar -->
                         <div x-show="!otpReceived" class="relative overflow-hidden bg-[#181C2A]/80 border border-blue-500/20 rounded-2xl p-5 flex flex-col sm:flex-row items-center justify-between gap-4 z-10">
                             <div class="absolute inset-0 bg-gradient-to-r from-blue-600/0 via-blue-600/10 to-blue-600/0 progress-animate opacity-50"></div>
                             
                             <div class="flex items-center gap-3 relative z-10">
                                 <div class="dot-pulse flex gap-1">
                                     <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                                     <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                                     <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                                 </div>
                                 <span class="text-sm font-bold text-slate-300">Menghubungkan ke gateway untuk mendeteksi SMS OTP...</span>
                             </div>
                             
                             <div class="font-mono text-blue-300 font-bold text-sm bg-blue-950 border border-blue-500/30 py-2 px-4 rounded-xl flex items-center gap-2 shrink-0 relative z-10 shadow-inner">
                                 <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                 <span id="otp-timer">20:00</span>
                             </div>
                         </div>
                     </div>
                     </div>
                     <% } %>
                     
                     <!-- Empty State -->
                 <div x-show="activeTab !== 'all' && !document.querySelectorAll('[x-show*=\'' + activeTab + '\']').length" class="text-center py-20 bg-white dark:bg-[#12121A] rounded-[3rem] border-2 border-dashed border-slate-200 dark:border-slate-800 mt-10 transition-colors">
                     <div class="w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-3xl mx-auto mb-6 flex items-center justify-center text-slate-400">
                         <svg class="w-10 h-10 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                     </div>
                     <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">Produk Belum Tersedia 📦</h3>
                     <p class="text-sm font-bold text-slate-500">Kategori ini sedang dalam pemeliharaan atau stok produk sedang kosong.</p>
                 </div>
            </div>

            <!-- Payment Method Modal -->
            <div x-show="showPaymentModal" style="display: none;" class="fixed inset-0 z-[100] flex items-center justify-center p-4">
                <div x-show="showPaymentModal" x-transition.opacity class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" @click="showPaymentModal = false"></div>
                <div x-show="showPaymentModal" x-transition.scale.95 class="relative bg-white dark:bg-[#12121A] w-full max-w-md rounded-3xl p-6 shadow-2xl border border-slate-200 dark:border-slate-800 z-10">
                    <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">Pilih Metode Pembayaran</h3>
                    <p class="text-xs text-slate-500 mb-6 font-medium">Sewa nomor virtual untuk <span class="font-bold text-slate-800 dark:text-slate-300" x-text="selectedCountryName"></span> seharga <span class="font-bold text-blue-500" x-text="'Rp ' + (selectedRate ? selectedRate.price.toLocaleString('id-ID') : 0)"></span></p>
                    
                    <div class="space-y-3">
                        <button @click="processPayment('balance')" class="w-full flex items-center justify-between p-4 rounded-2xl border-2 border-slate-200 dark:border-slate-800 hover:border-blue-500 bg-slate-50 dark:bg-slate-900/50 transition-all text-left group">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-xl bg-blue-500/10 text-blue-500 flex items-center justify-center shrink-0">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                                </div>
                                <div>
                                    <h4 class="font-bold text-slate-900 dark:text-white text-sm">Saldo Akun</h4>
                                    <p class="text-[10px] text-slate-500 font-medium mt-0.5">Potong langsung dari saldo web</p>
                                </div>
