                                                     ? 'border-emerald-500/20 dark:border-emerald-500/10 hover:border-emerald-500/60' 
                                                     : rate.type === 'Tertinggi / Premium' 
                                                       ? 'border-violet-500/20 dark:border-violet-500/10 hover:border-violet-500/60 shadow-lg shadow-violet-500/5' 
                                                       : 'border-blue-500/20 dark:border-blue-500/10 hover:border-blue-500/60'"
                                      >
                                          <!-- Glow for Premium -->
                                          <div x-show="rate.type === 'Tertinggi / Premium'" class="absolute top-0 right-0 w-24 h-24 bg-violet-600/10 rounded-full blur-2xl pointer-events-none"></div>

                                          <!-- Card Header / Badges -->
