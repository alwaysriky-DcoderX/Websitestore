<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../../partials/head') %>
</head>
<body class="bg-[#F4F7FA] dark:bg-[#09090B] text-slate-800 dark:text-slate-200 antialiased transition-colors duration-300">
    
    <%- include('../../partials/admin-sidebar') %>

    <!-- Main Content -->
    <main class="lg:ml-64 min-h-screen flex flex-col">
        <header class="h-16 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl border-b border-slate-200 dark:border-slate-700 sticky top-0 z-30 flex items-center justify-between px-4 sm:px-6 transition-colors shrink-0">
            <div class="flex items-center gap-3">
                <button onclick="window.uiCore.toggleSidebar()" class="p-2 -ml-2 text-slate-400 hover:text-slate-600 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700/50 rounded-xl transition-all active:scale-95 lg:hidden">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <h1 class="text-base sm:text-lg font-bold text-slate-800 dark:text-white truncate max-w-[120px] sm:max-w-none">Products</h1>
            </div>
            <div class="flex items-center gap-2 overflow-x-auto max-w-[60%] sm:max-w-none no-scrollbar">
                <a href="/admin/products/new/panel" class="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-xs font-bold transition whitespace-nowrap shrink-0">
                    + Panel
                </a>
                <a href="/admin/products/new/app" class="px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-xs font-bold transition whitespace-nowrap shrink-0">
                    + App
                </a>
                <a href="/admin/products/new/script" class="px-3 py-1.5 bg-purple-600 hover:bg-purple-700 text-white rounded-lg text-xs font-bold transition whitespace-nowrap shrink-0">
                    + Script
                </a>
                <a href="/admin/products/new/smm" class="px-3 py-1.5 bg-orange-600 hover:bg-orange-700 text-white rounded-lg text-xs font-bold transition whitespace-nowrap shrink-0">
                    + SMM
                </a>
            </div>
        </header>

        <div class="flex-1 p-4 sm:p-6">
            
            <!-- Modern Grid/List Wrapper -->
            <div class="bg-white dark:bg-[#12121A] rounded-3xl border border-slate-200/80 dark:border-slate-800/80 shadow-xl overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="bg-slate-50/80 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800/60">
                                <th class="py-4 px-6 text-slate-400 dark:text-slate-500 font-bold text-[10px] uppercase tracking-widest">Product Info</th>
                                <th class="py-4 px-6 text-slate-400 dark:text-slate-500 font-bold text-[10px] uppercase tracking-widest">Category</th>
                                <th class="py-4 px-6 text-slate-400 dark:text-slate-500 font-bold text-[10px] uppercase tracking-widest">Price</th>
                                <th class="py-4 px-6 text-slate-400 dark:text-slate-500 font-bold text-[10px] uppercase tracking-widest text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                            <% products.forEach(p => { %>
                                <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/40 transition-colors group">
                                    <td class="py-4 px-6">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center shrink-0 border border-slate-200 dark:border-slate-700 group-hover:scale-105 transition-transform">
                                                <% if (p.iconSVG) { %>
                                                    <div class="w-5 h-5 text-slate-500 dark:text-slate-400"><%- p.iconSVG %></div>
                                                <% } else { %>
                                                    <img src="<%= p.image %>" class="w-full h-full object-cover rounded-xl" onerror="this.src='/img/default-product.png'">
                                                <% } %>
                                            </div>
                                            <div>
                                                <div class="font-black text-slate-900 dark:text-white text-sm"><%= p.name %></div>
                                                <div class="text-[10px] font-bold text-slate-400 dark:text-slate-500 mt-0.5">ID: <%= p.id.split('-')[0] %></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 px-6">
                                        <% if (p.category) { %>
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest"
                                                  class="bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20">
                                                <%= p.category.name %>
                                            </span>
                                        <% } else { %>
                                            <span class="text-slate-400">-</span>
                                        <% } %>
                                    </td>
                                    <td class="py-4 px-6">
                                        <div class="text-sm font-black text-emerald-600 dark:text-emerald-400">Rp <%= p.price.toLocaleString('id-ID') %></div>
                                    </td>
                                    <td class="py-4 px-6 text-right">
                                        <div class="flex items-center justify-end gap-2">
                                            <% if (p.category && (p.category.type === 'premium_app' || p.category.type === 'script')) { %>
                                                <a href="/admin/products/stock/<%= p.id %>" class="p-2 text-slate-400 hover:text-blue-500 bg-slate-50 hover:bg-blue-50 dark:bg-slate-900 dark:hover:bg-blue-500/10 rounded-lg transition-colors tooltip" title="Manage Stock">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                                                </a>
                                            <% } %>
                                            <% if (p.category && p.category.type === 'pterodactyl') { %>
                                                <a href="/admin/products/edit/panel/<%= p.id %>" class="p-2 text-slate-400 hover:text-amber-500 bg-slate-50 hover:bg-amber-50 dark:bg-slate-900 dark:hover:bg-amber-500/10 rounded-lg transition-colors tooltip" title="Edit Product">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                                </a>
                                            <% } %>
                                            <a href="/admin/products/delete/<%= p.id %>" class="p-2 text-slate-400 hover:text-red-500 bg-slate-50 hover:bg-red-50 dark:bg-slate-900 dark:hover:bg-red-500/10 rounded-lg transition-colors tooltip" title="Delete" onclick="return confirm('Hapus produk ini?')">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if(products.length === 0) { %>
                                <tr>
                                    <td colspan="4" class="py-12 text-center">
                                        <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-slate-50 dark:bg-slate-800/50 mb-3">
                                            <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                                        </div>
                                        <p class="text-sm font-bold text-slate-500">Belum ada produk.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
    </main>
</body>
</html>


