<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../partials/head') %>

</head>
<body class="bg-[#F4F7FA] dark:bg-[#09090B] text-slate-800 dark:text-slate-200 antialiased transition-colors duration-300">
    
    <%- include('../partials/admin-sidebar') %>

    <!-- Main Content Area -->
    <main class="lg:ml-64 min-h-screen flex flex-col">
        <!-- Top Navbar -->
        <header class="h-16 bg-white/90 dark:bg-[#09090B]/90 backdrop-blur-xl border-b border-slate-200/80 dark:border-slate-800/80 flex items-center justify-between px-4 sm:px-6 transition-colors duration-300 shrink-0 sticky top-0 z-30">
            <div class="flex items-center gap-4">
                <button onclick="window.uiCore.toggleSidebar()" class="p-2 -ml-2 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all active:scale-95">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <h1 class="text-lg font-black text-slate-900 dark:text-white tracking-tight">Admin Overview</h1>
            </div>
            
            <div class="flex items-center gap-4">
                <button onclick="window.uiCore.toggleTheme()" class="p-2.5 text-slate-500 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800 rounded-xl transition-all active:scale-90 duration-200">
                    <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                </button>
                <div class="h-6 w-px bg-slate-200 dark:bg-slate-800"></div>
                <div class="flex items-center gap-3">
                    <div class="hidden md:flex flex-col items-end">
                        <span class="text-xs font-black text-slate-900 dark:text-white leading-tight"><%= user.username %></span>
                        <span class="text-[9px] font-black text-purple-600 dark:text-purple-400 uppercase tracking-widest"><%= user.role %></span>
                    </div>
                    <div class="w-8 h-8 bg-purple-600 text-white rounded-xl flex items-center justify-center font-black text-xs shadow-md"><%= user.username.charAt(0).toUpperCase() %></div>
                </div>
            </div>
        </header>

        <div class="flex-1 p-4 sm:p-6 lg:p-8 space-y-6">
            <!-- Glow background circles -->
            <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
                <div class="absolute top-[20%] right-[10%] w-[30%] h-[30%] bg-blue-600/5 dark:bg-blue-600/10 rounded-full blur-[120px] animate-pulse"></div>
            </div>

            <!-- Stats Metric Cards Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 relative z-10" data-aos="fade-up">
                <!-- Revenue Card -->
                <div class="bg-white dark:bg-[#12121A] p-6 rounded-[2rem] border border-slate-200 dark:border-slate-800 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-emerald-500/30">
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Keuntungan</span>
                        <div class="w-10 h-10 bg-emerald-50 dark:bg-emerald-500/10 rounded-xl flex items-center justify-center text-emerald-600 dark:text-emerald-400 shadow-inner">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                    </div>
                    <p class="text-[10px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-wider">Total Pendapatan</p>
                    <p class="text-2xl font-black text-slate-900 dark:text-white tracking-tight mt-1">Rp <%= stats.revenue.toLocaleString('id-ID') %></p>
                </div>

                <!-- Orders Card -->
                <div class="bg-white dark:bg-[#12121A] p-6 rounded-[2rem] border border-slate-200 dark:border-slate-800 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-500/30">
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Transaksi</span>
                        <div class="w-10 h-10 bg-blue-50 dark:bg-blue-500/10 rounded-xl flex items-center justify-center text-blue-600 dark:text-blue-400 shadow-inner">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        </div>
                    </div>
                    <p class="text-[10px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-wider">Total Transaksi</p>
                    <p class="text-2xl font-black text-slate-900 dark:text-white tracking-tight mt-1"><%= stats.orderCount %> Pesanan</p>
                </div>

                <!-- Users Card -->
                <div class="bg-white dark:bg-[#12121A] p-6 rounded-[2rem] border border-slate-200 dark:border-slate-800 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-purple-500/30">
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Pengguna</span>
                        <div class="w-10 h-10 bg-purple-50 dark:bg-purple-500/10 rounded-xl flex items-center justify-center text-purple-600 dark:text-purple-400 shadow-inner">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        </div>
                    </div>
                    <p class="text-[10px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-wider">Total Pengguna</p>
                    <p class="text-2xl font-black text-slate-900 dark:text-white tracking-tight mt-1"><%= stats.userCount %> Akun</p>
                </div>

                <!-- Products Card -->
                <div class="bg-white dark:bg-[#12121A] p-6 rounded-[2rem] border border-slate-200 dark:border-slate-800 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-amber-500/30">
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Infrastruktur</span>
                        <div class="w-10 h-10 bg-amber-50 dark:bg-amber-500/10 rounded-xl flex items-center justify-center text-amber-600 dark:text-amber-400 shadow-inner">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                        </div>
                    </div>
                    <p class="text-[10px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-wider">Layanan & Node</p>
                    <p class="text-2xl font-black text-slate-900 dark:text-white tracking-tight mt-1"><%= stats.productCount %> / <%= stats.nodeCount %> Items</p>
                </div>
            </div>

            <!-- Quick Actions Section -->
            <div class="bg-white dark:bg-[#12121A] rounded-[2rem] border border-slate-200 dark:border-slate-800 p-6 sm:p-8 shadow-sm transition-colors relative z-10" data-aos="fade-up" data-aos-delay="100">
                <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-500/20 mb-2 uppercase tracking-widest">Akses Cepat</span>
                <h2 class="text-lg font-black text-slate-900 dark:text-white tracking-tight mb-5">Manajemen Konten & Produk</h2>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
                    <a href="/admin/products/new/panel" class="group flex items-center justify-between px-5 py-4 bg-blue-50 dark:bg-blue-600/10 hover:bg-blue-600 dark:hover:bg-blue-600 text-blue-600 dark:text-blue-400 hover:text-white border border-blue-100 dark:border-blue-500/20 rounded-2xl text-xs font-black transition-all duration-300 hover:-translate-y-0.5 active:scale-[0.98]">
                        <span>+ Tambah Panel Ptero</span>
                        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                    <a href="/admin/products/new/app" class="group flex items-center justify-between px-5 py-4 bg-emerald-50 dark:bg-emerald-600/10 hover:bg-emerald-600 dark:hover:bg-emerald-600 text-emerald-600 dark:text-emerald-400 hover:text-white border border-emerald-100 dark:border-emerald-500/20 rounded-2xl text-xs font-black transition-all duration-300 hover:-translate-y-0.5 active:scale-[0.98]">
                        <span>+ Tambah App Stock</span>
                        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                    <a href="/admin/products/new/script" class="group flex items-center justify-between px-5 py-4 bg-purple-50 dark:bg-purple-600/10 hover:bg-purple-600 dark:hover:bg-purple-600 text-purple-600 dark:text-purple-400 hover:text-white border border-purple-100 dark:border-purple-500/20 rounded-2xl text-xs font-black transition-all duration-300 hover:-translate-y-0.5 active:scale-[0.98]">
                        <span>+ Tambah Script</span>
                        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                    <a href="/admin/categories" class="group flex items-center justify-between px-5 py-4 bg-amber-50 dark:bg-amber-600/10 hover:bg-amber-600 dark:hover:bg-amber-600 text-amber-600 dark:text-amber-400 hover:text-white border border-amber-100 dark:border-amber-500/20 rounded-2xl text-xs font-black transition-all duration-300 hover:-translate-y-0.5 active:scale-[0.98]">
                        <span>Kelola Kategori</span>
                        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                </div>
            </div>

            <!-- Recent Transactions Section -->
            <div class="bg-white dark:bg-[#12121A] rounded-[2rem] border border-slate-200 dark:border-slate-800 p-6 sm:p-8 shadow-sm transition-colors relative z-10" data-aos="fade-up" data-aos-delay="200">
                <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[9px] font-black bg-purple-50 dark:bg-purple-500/10 text-purple-600 dark:text-purple-400 border border-purple-100 dark:border-purple-500/20 mb-2 uppercase tracking-widest">Log Transaksi</span>
                <h2 class="text-lg font-black text-slate-900 dark:text-white tracking-tight mb-5">5 Transaksi Terbaru Masuk</h2>
                
                <div class="overflow-x-auto w-full rounded-2xl border border-slate-100 dark:border-slate-800/80">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 dark:bg-slate-900/60 text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest border-b border-slate-100 dark:border-slate-800/60">
                                <th class="py-4 px-6">ID Invoice</th>
                                <th class="py-4 px-6">Pengguna</th>
                                <th class="py-4 px-6">Produk</th>
                                <th class="py-4 px-6">Nominal</th>
                                <th class="py-4 px-6 text-center">Status</th>
                                <th class="py-4 px-6">Waktu</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60 text-xs font-bold text-slate-700 dark:text-slate-300">
                            <% if (recentOrders.length > 0) { %>
                                <% recentOrders.forEach(order => { %>
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-900/30 transition-colors">
                                        <td class="py-4.5 px-6 font-mono text-blue-600 dark:text-blue-400">#<%= order.orderId %></td>
                                        <td class="py-4.5 px-6">
                                            <div class="flex flex-col">
                                                <span class="text-slate-900 dark:text-white font-black"><%= order.user ? order.user.username : 'Guest' %></span>
                                                <span class="text-[10px] text-slate-400 font-bold"><%= order.user ? order.user.email : order.guestContact %></span>
                                            </div>
                                        </td>
                                        <td class="py-4.5 px-6"><%= order.productNameSnap %></td>
                                        <td class="py-4.5 px-6 font-black text-slate-900 dark:text-white">Rp <%= order.amount.toLocaleString('id-ID') %></td>
                                        <td class="py-4.5 px-6 text-center">
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-xl text-[9px] font-black uppercase tracking-widest border <%= 
                                                order.status === 'completed' ? 'bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border-emerald-100 dark:border-emerald-600/20' : 
                                                order.status === 'pending' ? 'bg-amber-50 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-100 dark:border-amber-600/20' : 
                                                'bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 border-red-100 dark:border-red-600/20' %>">
                                                <%= order.status %>
                                            </span>
                                        </td>
                                        <td class="py-4.5 px-6 text-slate-400 dark:text-slate-500 text-[10px]"><%= new Date(order.createdAt).toLocaleString('id-ID', { hour: '2-digit', minute:'2-digit', day: '2-digit', month: 'short' }) %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-10 text-slate-400">Belum ada riwayat transaksi masuk.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 600, easing: 'ease-out-cubic', once: true, offset: 40 });
    </script>
</body>
</html>
