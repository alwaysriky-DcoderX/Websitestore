<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
</head>
<body class="bg-[#F4F7FA] dark:bg-[#09090B] text-slate-800 dark:text-slate-200 antialiased transition-colors duration-300">
    
    <%- include('../partials/admin-sidebar') %>

    <!-- Main Content Area -->
    <main class="lg:ml-64 min-h-screen flex flex-col">
        <!-- Top Navbar -->
        <header class="h-16 bg-white/90 dark:bg-[#09090B]/90 backdrop-blur-xl border-b border-slate-200/80 dark:border-slate-800/80 flex items-center justify-between px-4 sm:px-6 transition-colors duration-300 shrink-0 sticky top-0 z-30">
            <div class="flex items-center gap-4">
                <button onclick="window.uiCore.toggleSidebar()" class="p-2 -ml-2 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all active:scale-95">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <h1 class="text-lg font-black text-slate-900 dark:text-white tracking-tight">Virtual Numbers / OTP Settings</h1>
            </div>
            
            <div class="flex items-center gap-4">
                <button onclick="window.uiCore.toggleTheme()" class="p-2.5 text-slate-500 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800 rounded-xl transition-all active:scale-90 duration-200">
                    <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                </button>
            </div>
        </header>

        <div class="flex-1 p-4 sm:p-6 lg:p-8 space-y-6">

            <!-- Flash Message -->
            <% if (req.session && req.session.flash) { %>
            <% const flash = req.session.flash; delete req.session.flash; %>
            <div class="<%= flash.type === 'success' ? 'bg-emerald-50 dark:bg-emerald-500/10 border-emerald-200 dark:border-emerald-500/20 text-emerald-700 dark:text-emerald-400' : 'bg-blue-50 dark:bg-blue-500/10 border-blue-200 dark:border-blue-500/20 text-blue-700 dark:text-blue-400' %> border rounded-2xl px-5 py-4 font-bold text-sm flex items-center gap-3">
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <%= flash.message %>
            </div>
            <% } %>

            <!-- SMSCode Balance Banner -->
            <div class="bg-gradient-to-r from-purple-600 to-indigo-600 rounded-[2rem] p-6 sm:p-8 text-white shadow-xl relative overflow-hidden" data-aos="fade-up">
                <div class="absolute right-0 top-0 w-80 h-80 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
                <div class="relative flex flex-col md:flex-row md:items-center justify-between gap-6">
                    <div>
                        <span class="inline-flex items-center gap-1.5 py-0.5 px-2 rounded-full text-[9px] font-black bg-white/10 text-purple-200 border border-white/10 uppercase tracking-widest mb-3">Live Provider Connection</span>
                        <h2 class="text-2xl sm:text-3xl font-black tracking-tight">SMSCode.gg Integration</h2>
                        <p class="text-sm text-purple-100 font-medium mt-1">Configure which virtual number services to sell and add dynamic pricing profit margins.</p>
                    </div>
                    <div class="bg-white/10 border border-white/10 rounded-3xl p-5 flex flex-col min-w-[200px]">
                        <span class="text-[9px] font-black text-purple-200 uppercase tracking-widest">Saldo SMSCode.gg</span>
                        <span class="text-2xl sm:text-3xl font-black mt-1">Rp <%= providerBalance.toLocaleString('id-ID') %></span>
                    </div>
                </div>
            </div>

            <!-- ═══════════════════════════════════════ -->
            <!-- GLOBAL ON/OFF CONTROL                   -->
            <!-- ═══════════════════════════════════════ -->
            <div class="bg-white dark:bg-[#12121A] rounded-[2rem] border border-slate-200 dark:border-slate-800 p-6 shadow-sm transition-colors" data-aos="fade-up" data-aos-delay="50">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-5">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-gradient-to-br from-red-500/20 to-emerald-500/20 rounded-2xl flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6 text-slate-700 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-base font-black text-slate-900 dark:text-white tracking-tight">Kontrol Global Layanan Nokos</h3>
                            <p class="text-xs text-slate-400 font-medium mt-0.5">Aktifkan atau nonaktifkan <strong>SEMUA</strong> layanan Nokos OTP sekaligus dengan satu klik.</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3 shrink-0">
                        <!-- Turn ALL OFF -->
                        <form action="/admin/nokos/toggle-all" method="POST">
                            <% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
                            <input type="hidden" name="action" value="off">
                            <button type="submit"
                                onclick="return confirm('Nonaktifkan SEMUA layanan Nokos OTP?')"
                                class="flex items-center gap-2 px-5 py-3 bg-red-50 dark:bg-red-500/10 hover:bg-red-100 dark:hover:bg-red-500/20 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-500/30 rounded-2xl font-black text-xs transition-all active:scale-95 shadow-sm">
                                <span class="w-2 h-2 rounded-full bg-red-500"></span>
                                Matikan Semua
                            </button>
                        </form>
                        <!-- Turn ALL ON -->
                        <form action="/admin/nokos/toggle-all" method="POST">
                            <% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
                            <input type="hidden" name="action" value="on">
                            <button type="submit"
                                onclick="return confirm('Aktifkan SEMUA layanan Nokos OTP?')"
                                class="flex items-center gap-2 px-5 py-3 bg-emerald-600 hover:bg-emerald-500 text-white rounded-2xl font-black text-xs transition-all active:scale-95 shadow-lg shadow-emerald-600/20">
                                <span class="w-2 h-2 rounded-full bg-emerald-300 animate-pulse"></span>
                                Aktifkan Semua
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Live status indicator -->
                <div class="mt-5 pt-5 border-t border-slate-100 dark:border-slate-800 flex flex-wrap gap-3 text-xs font-bold">
                    <% const activeCount = services.filter(s => s.isActive).length; %>
                    <% const totalCount = services.length; %>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-100 dark:border-emerald-500/20">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                        <%= activeCount %> Layanan Aktif
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-slate-50 dark:bg-slate-800 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700">
                        <%= totalCount - activeCount %> Layanan Nonaktif
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-slate-50 dark:bg-slate-800 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700">
                        Total: <%= totalCount %> Layanan
                    </span>
                </div>
            </div>

            <!-- Services Config Card -->
            <div class="bg-white dark:bg-[#12121A] rounded-[2rem] border border-slate-200 dark:border-slate-800 p-6 sm:p-8 shadow-sm transition-colors" data-aos="fade-up" data-aos-delay="100">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h3 class="text-lg font-black text-slate-900 dark:text-white tracking-tight">Daftar Layanan OTP (Nokos)</h3>
                        <p class="text-xs text-slate-400 font-medium mt-0.5">Toggle status aktif untuk memunculkan layanan di marketplace dan atur margin harga jual.</p>
                    </div>
                </div>

                <form action="/admin/nokos/save" method="POST">
                    <!-- Dynamic CSRF Token if present -->
                    <% if (locals.csrfToken) { %>
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <% } %>

                    <div class="overflow-x-auto w-full rounded-2xl border border-slate-100 dark:border-slate-800/80 mb-6">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-slate-50 dark:bg-slate-900/60 text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest border-b border-slate-100 dark:border-slate-800/60">
                                    <th class="py-4 px-6 w-20 text-center">Status</th>
                                    <th class="py-4 px-6">Nama Layanan</th>
                                    <th class="py-4 px-6">Platform Code</th>
                                    <th class="py-4 px-6">Margin Keuntungan (Rp)</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60 text-xs font-bold text-slate-700 dark:text-slate-300">
                                <% services.forEach(service => { %>
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-900/30 transition-colors">
                                        <td class="py-4 px-6 text-center">
                                            <label class="relative inline-flex items-center cursor-pointer">
                                                <input type="checkbox" name="active_<%= service.id %>" class="sr-only peer" <%= service.isActive ? 'checked' : '' %>>
                                                <div class="w-9 h-5 bg-slate-200 dark:bg-slate-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-purple-600"></div>
                                            </label>
                                            <input type="hidden" name="name_<%= service.id %>" value="<%= service.name %>">
                                        </td>
                                        <td class="py-4 px-6">
                                            <div class="flex items-center gap-2">
                                                <span class="w-2 h-2 rounded-full <%= service.isActive ? 'bg-emerald-500 animate-pulse' : 'bg-slate-300 dark:bg-slate-600' %>"></span>
                                                <span class="text-slate-900 dark:text-white font-black text-sm"><%= service.name %></span>
                                            </div>
                                        </td>
                                        <td class="py-4 px-6 font-mono text-[11px] text-slate-400 dark:text-slate-500">
                                            <%= service.code %> (ID: <%= service.id %>)
                                        </td>
                                        <td class="py-4 px-6">
                                            <div class="flex items-center gap-2 max-w-[200px]">
                                                <span class="text-slate-400 font-bold">Rp</span>
                                                <input type="number" name="margin_<%= service.id %>" value="<%= service.margin %>" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs font-bold text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-purple-600 focus:border-transparent transition-all" min="0" placeholder="0">
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div class="flex justify-end">
                        <button type="submit" class="px-8 py-3.5 bg-purple-600 hover:bg-purple-500 text-white rounded-2xl font-black text-sm shadow-lg shadow-purple-600/30 transition-all duration-300 hover:-translate-y-0.5 active:scale-[0.98]">
                            Simpan Perubahan
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 600, easing: 'ease-out-cubic', once: true, offset: 40 });
    </script>
</body>
</html>

