<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../../partials/head') %>
</head>
<body class="bg-[#F4F7FA] dark:bg-[#09090B] text-slate-800 dark:text-slate-200 antialiased transition-colors duration-300">
    
    <%- include('../../partials/admin-sidebar') %>

    <!-- Main Content -->
    <main class="lg:ml-64 min-h-screen flex flex-col">
        <header class="h-16 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl border-b border-slate-200 dark:border-slate-700 sticky top-0 z-30 flex items-center justify-between px-4 sm:px-6 transition-colors">
            
            <button onclick="window.uiCore.toggleSidebar()" class="p-2 -ml-2 text-slate-400 hover:text-slate-600 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700/50 rounded-xl transition-all active:scale-95">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
            <h1 class="text-xl font-bold text-slate-800 dark:text-white">Pterodactyl Nodes (PLTA)</h1>
            <button onclick="document.getElementById('addNodeModal').classList.remove('hidden')" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition">
                + Add Node
            </button>
        </header>

        <div class="flex-1 p-4 sm:p-6">
            <div class="overflow-x-auto rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm bg-white dark:bg-slate-800">
                <table class="min-w-full text-left border-collapse whitespace-nowrap">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-slate-900/50 border-b border-slate-200 dark:border-slate-700">
                            <th class="py-3 px-6 text-slate-400 font-medium text-sm">Node Name</th>
                            <th class="py-3 px-6 text-slate-400 font-medium text-sm">Location</th>
                            <th class="py-3 px-6 text-slate-400 font-medium text-sm">Domain / Panel</th>
                            <th class="py-3 px-6 text-slate-400 font-medium text-sm">Loc/Egg/Nest ID</th>
                            <th class="py-3 px-6 text-slate-400 font-medium text-sm">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        <% nodes.forEach(node => { %>
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/20 transition-colors">
                                <td class="py-4 px-6 text-slate-900 dark:text-white font-bold"><%= node.name %></td>
                                <td class="py-3 px-6 text-sm">
                                    <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-900/50 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700 rounded-lg text-[10px] font-black uppercase tracking-widest">
                                        <%= node.location || 'Indonesia' %>
                                    </span>
                                </td>
                                <td class="py-3 px-6 text-sm text-slate-400">
                                    <div class="truncate max-w-xs"><%= node.domain %></div>
                                    <div class="text-[10px] font-mono text-slate-500">API: <%= node.apiKey.substring(0, 10) %>...</div>
                                </td>
                                <td class="py-3 px-6 text-sm text-slate-400 font-mono">
                                    <span class="text-blue-400"><%= node.locationId %></span> / 
                                    <span class="text-purple-400"><%= node.eggId %></span> / 
                                    <span class="text-emerald-400"><%= node.nestId %></span>
                                </td>
                                <td class="py-3 px-6 text-sm">
                                    <div class="flex items-center gap-3">
                                        <a href="/admin/nodes/edit/<%= node.id %>" class="text-blue-500 hover:text-blue-400 font-medium">Edit</a>
                                        <a href="/admin/nodes/delete/<%= node.id %>" class="text-red-400 hover:text-red-300 font-medium" onclick="return confirm('Are you sure you want to delete this node? All products linked to it might break!')">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        <% if(nodes.length === 0) { %>
                            <tr><td colspan="4" class="py-8 text-center text-slate-500">No nodes found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <!-- Add Node Modal -->
    <div id="addNodeModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4 overflow-y-auto">
        <div class="bg-slate-800 border border-slate-700 rounded-2xl p-6 max-w-md w-full shadow-2xl my-auto">
            <h3 class="text-xl font-bold text-white mb-6">Add New Node / Panel</h3>
            <form action="/admin/nodes" method="POST" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div>
                    <label class="block text-sm font-medium text-slate-400 mb-1">Display Name</label>
                    <input type="text" name="name" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-white focus:ring-2 focus:ring-blue-500 outline-none" placeholder="e.g. Python Server">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-400 mb-1">Panel Domain (URL)</label>
                    <input type="url" name="domain" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-white focus:ring-2 focus:ring-blue-500 outline-none" placeholder="https://panel.example.com">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-400 mb-1">Location (ID, SG, US, etc.)</label>
                    <input type="text" name="location" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-white focus:ring-2 focus:ring-blue-500 outline-none" placeholder="e.g. Indonesia">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-400 mb-1">Application API Key (PLTA)</label>
                    <input type="text" name="apiKey" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-white focus:ring-2 focus:ring-blue-500 outline-none" placeholder="ptla_xxxxxxxxxxxx">
                </div>
                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-1">Location ID</label>
                        <input type="number" name="locationId" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-white focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-1">Egg ID</label>
                        <input type="number" name="eggId" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-white focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-1">Nest ID</label>
                        <input type="number" name="nestId" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-white focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                </div>
                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="document.getElementById('addNodeModal').classList.add('hidden')" class="flex-1 bg-slate-700 hover:bg-slate-600 text-white font-semibold py-2 rounded-xl transition-colors">Cancel</button>
                    <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-xl transition-colors">Save Config</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>


