                    <p class="text-slate-600 dark:text-slate-500 dark:text-slate-400 text-sm font-medium mb-5">Beli lisensi script. Link download dan instruksi instalasi langsung dikembalikan setelah order berhasil.</p>
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Request Body</h4>
                    <table class="w-full param-table mb-5">
                        <thead><tr><th>Parameter</th><th>Tipe</th><th>Wajib</th><th>Keterangan</th></tr></thead>
                        <tbody>
                            <tr><td class="mono">productId</td><td class="italic text-slate-500 dark:text-slate-400">String</td><td class="req">Ya</td><td>ID produk dari <code class="text-blue-4000">/products?type=script</code></td></tr>
                            <tr><td class="mono">paymentType</td><td class="italic text-slate-500 dark:text-slate-400">String</td><td class="req">Ya</td><td><code class="text-blue-400">"direct"</code> atau <code class="text-blue-400">"qris"</code></td></tr>
                            <tr><td class="mono">voucherCode</td><td class="italic text-slate-500 dark:text-slate-400">String</td><td class="opt">Optional</td><td>Kode voucher diskon</td></tr>
                        </tbody>
                    </table>
                    <div class="code-block-wrapper bg-slate-900 dark:bg-[#0A0C18] rounded-2xl p-5 border border-slate-800 dark:border-slate-200 dark:border-white/5 mb-5">
                        <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                        <pre class="text-sm font-mono leading-relaxed overflow-x-auto">{
  <span class="text-blue-400">"productId"</span>: <span class="text-green-400">"prod_bot_wa"</span>,
  <span class="text-blue-400">"paymentType"</span>: <span class="text-green-400">"direct"</span>
}</pre>
                    </div>
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Response (Sukses)</h4>
                    <div class="code-block-wrapper bg-slate-900 dark:bg-[#0A0C18] rounded-2xl p-5 border border-slate-800 dark:border-slate-200 dark:border-white/5">
                        <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                        <pre class="text-sm font-mono leading-relaxed overflow-x-auto">{
  <span class="text-blue-400">"success"</span>: <span class="text-purple-400">true</span>,
  <span class="text-blue-400">"orderId"</span>: <span class="text-green-400">"API-SCR442"</span>,
  <span class="text-blue-400">"status"</span>: <span class="text-green-400">"completed"</span>,
  <span class="text-blue-400">"data"</span>: {
    <span class="text-blue-400">"downloadUrl"</span>: <span class="text-green-400">"https://cdn.yourdomain.com/scripts/bot-wa-v2.zip"</span>,
    <span class="text-blue-400">"instructions"</span>: <span class="text-green-400">"1. Extract zip\n2. npm install\n3. node index.js"</span>,
    <span class="text-blue-400">"licenseKey"</span>: <span class="text-green-400">"LIC-XXXXXXXX-XXXXXXXX"</span>
  }
}</pre>
                    </div>
                </section>

            </div>

            <!-- ════════════════════════════════════
                 SHARED: Balance + Order Status (shown for all categories)
            ════════════════════════════════════ -->
            <div class="space-y-12 mt-12" x-show="true">
                <section id="balance" class="border-t border-slate-200 dark:border-white/5 pt-10">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="badge-get text-[10px] font-black uppercase tracking-wider px-2 py-1 rounded-md">GET</span>
                        <h2 class="text-xl font-black text-slate-900 dark:text-white">/api/v1/account</h2>
                    </div>
                    <p class="text-slate-600 dark:text-slate-500 dark:text-slate-400 text-sm font-medium mb-5">Cek saldo dan informasi akun reseller kamu.</p>
                    <div class="code-block-wrapper bg-slate-900 dark:bg-[#0A0C18] rounded-2xl p-5 border border-slate-800 dark:border-slate-200 dark:border-white/5">
                        <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                        <pre class="text-sm font-mono leading-relaxed overflow-x-auto">{
  <span class="text-blue-400">"success"</span>: <span class="text-purple-400">true</span>,
  <span class="text-blue-400">"data"</span>: {
    <span class="text-blue-400">"username"</span>: <span class="text-green-400">"AlxzyReseller"</span>,
    <span class="text-blue-400">"role"</span>: <span class="text-green-400">"reseller"</span>,
    <span class="text-blue-400">"balance"</span>: <span class="text-orange-400">150000</span>,
    <span class="text-blue-400">"margin"</span>: <span class="text-orange-400">5000</span>
  }
}</pre>
                    </div>
                </section>

                <section id="deposit" class="border-t border-slate-200 dark:border-white/5 pt-10">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="badge-post text-[10px] font-black uppercase tracking-wider px-2 py-1 rounded-md">POST</span>
                        <h2 class="text-xl font-black text-slate-900 dark:text-white">/api/v1/deposit</h2>
                    </div>
                    <p class="text-slate-600 dark:text-slate-500 dark:text-slate-400 text-sm font-medium mb-5">Generate QRIS untuk top-up saldo reseller kamu.</p>
                    <table class="w-full param-table mb-5">
                        <thead><tr><th>Parameter</th><th>Tipe</th><th>Wajib</th><th>Keterangan</th></tr></thead>
                        <tbody>
                            <tr><td class="mono">amount</td><td class="italic text-slate-500 dark:text-slate-400">Number</td><td class="req">Ya</td><td>Jumlah deposit dalam Rupiah (min Rp 1.000)</td></tr>
                        </tbody>
                    </table>
                    <div class="code-block-wrapper bg-slate-900 dark:bg-[#0A0C18] rounded-2xl p-5 border border-slate-800 dark:border-slate-200 dark:border-white/5">
                        <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                        <pre class="text-sm font-mono leading-relaxed overflow-x-auto">{
  <span class="text-blue-400">"success"</span>: <span class="text-purple-400">true</span>,
  <span class="text-blue-400">"data"</span>: {
    <span class="text-blue-400">"depositId"</span>: <span class="text-green-400">"DEP-XYZ123"</span>,
    <span class="text-blue-400">"amount"</span>: <span class="text-orange-400">50000</span>,
    <span class="text-blue-400">"qris_data"</span>: <span class="text-green-400">"00020101021126570011ID.ESPAY..."</span>,
    <span class="text-blue-400">"expiresAt"</span>: <span class="text-green-400">"2024-01-01T12:15:00Z"</span>
  }
}</pre>
                    </div>
                </section>

                <section id="order-status" class="border-t border-slate-200 dark:border-white/5 pt-10">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="badge-get text-[10px] font-black uppercase tracking-wider px-2 py-1 rounded-md">GET</span>
                        <h2 class="text-xl font-black text-slate-900 dark:text-white">/api/v1/order/:orderId</h2>
                    </div>
                    <p class="text-slate-600 dark:text-slate-500 dark:text-slate-400 text-sm font-medium mb-5">Cek status dan detail order berdasarkan Order ID yang didapat dari endpoint POST /order.</p>
                    <div class="code-block-wrapper bg-slate-900 dark:bg-[#0A0C18] rounded-2xl p-5 border border-slate-800 dark:border-slate-200 dark:border-white/5">
                        <button class="copy-btn" onclick="copyCode(this)">Copy</button>
                        <pre class="text-sm font-mono leading-relaxed overflow-x-auto">{
  <span class="text-blue-400">"success"</span>: <span class="text-purple-400">true</span>,
  <span class="text-blue-400">"data"</span>: {
    <span class="text-blue-400">"orderId"</span>: <span class="text-green-400">"API-XYZ123"</span>,
    <span class="text-blue-400">"status"</span>: <span class="text-green-400">"completed"</span>,  <span class="text-slate-500">// pending | completed | failed | cancelled</span>
    <span class="text-blue-400">"productName"</span>: <span class="text-green-400">"Netflix Premium 1 Bulan"</span>,
    <span class="text-blue-400">"paidAt"</span>: <span class="text-green-400">"2024-01-01T12:00:00Z"</span>,
    <span class="text-blue-400">"data"</span>: { <span class="text-slate-500">/* hasil sesuai kategori produk */</span> }
  }
}</pre>
                    </div>
                </section>
            </div>

            <div class="mt-24 pb-8 text-center text-slate-600 text-xs font-medium">
                <%= settings.web_name %> API Docs &mdash; Built for resellers 🚀
            </div>
        </main>
    </div>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ once: true, duration: 500 });

        // Theme
        if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }

        // Copy button
        function copyCode(btn) {
            const pre = btn.closest('.code-block-wrapper').querySelector('pre');
            navigator.clipboard.writeText(pre.textContent.trim()).then(() => {
                btn.textContent = 'Copied!';
                btn.classList.add('copied');
                setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
            });
        }

        // Alpine component
        function docsApp() {
            const categories = {
                nokos: {
                    desc: 'Integrasikan Virtual OTP Number ke bot/aplikasi Anda. Beli nomor virtual real-time, monitor kode SMS, dan batalkan order kapan saja.',
                    nav: [
                        { id: 'auth', label: 'Authentication' },
                        { id: 'nokos-services', label: '/nokos/services', method: 'GET' },
                        { id: 'nokos-rates', label: '/nokos/rates/:id', method: 'GET' },
                        { id: 'nokos-order', label: '/nokos/order', method: 'POST' },
                        { id: 'nokos-check', label: '/nokos/order/:id', method: 'GET' },
                        { id: 'nokos-cancel', label: '/nokos/order/:id/cancel', method: 'POST' },
                        { id: 'balance', label: '/account', method: 'GET' },
                        { id: 'deposit', label: '/deposit', method: 'POST' },
                    ]
                },
                app: {
                    desc: 'Jual akun Premium App (Netflix, Spotify, YouTube dll.) ke customer Anda. Order langsung dapat email & password akun.',
                    nav: [
                        { id: 'auth', label: 'Authentication' },
                        { id: 'app-products', label: '/products?type=premium_app', method: 'GET' },
                        { id: 'app-order', label: '/order', method: 'POST' },
                        { id: 'order-status', label: '/order/:id', method: 'GET' },
                        { id: 'balance', label: '/account', method: 'GET' },
                        { id: 'deposit', label: '/deposit', method: 'POST' },
                    ]
                },
                panel: {
                    desc: 'Deploy Server Pterodactyl secara otomatis. Tentukan username & password panel, sistem deploy dalam hitungan detik.',
                    nav: [
                        { id: 'auth', label: 'Authentication' },
                        { id: 'panel-products', label: '/products?type=pterodactyl', method: 'GET' },
                        { id: 'panel-order', label: '/order', method: 'POST' },
                        { id: 'order-status', label: '/order/:id', method: 'GET' },
                        { id: 'balance', label: '/account', method: 'GET' },
                        { id: 'deposit', label: '/deposit', method: 'POST' },
                    ]
                },
                script: {
                    desc: 'Beli lisensi script dan bot digital. Link download langsung dikirim setelah pembayaran berhasil.',
                    nav: [
                        { id: 'auth', label: 'Authentication' },
                        { id: 'script-products', label: '/products?type=script', method: 'GET' },
                        { id: 'script-order', label: '/order', method: 'POST' },
                        { id: 'order-status', label: '/order/:id', method: 'GET' },
                        { id: 'balance', label: '/account', method: 'GET' },
                        { id: 'deposit', label: '/deposit', method: 'POST' },
                    ]
                }
            };

            return {
                mobileOpen: false,
                activeCategory: 'nokos',
                activeSection: 'auth',
                sidebarItems: [],
                categoryDesc: '',

                setCategory(cat) {
                    this.activeCategory = cat;
                    this.sidebarItems = categories[cat].nav;
                    this.categoryDesc = categories[cat].desc;
                    this.mobileOpen = false;
                    // scroll to top
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                },

                init() {
                    this.setCategory('nokos');
                    // Scroll spy
                    const observer = new IntersectionObserver((entries) => {
                        entries.forEach(e => {
                            if (e.isIntersecting) this.activeSection = e.target.id;
                        });
                    }, { rootMargin: '-30% 0px -60% 0px' });

                    document.querySelectorAll('section[id]').forEach(s => observer.observe(s));
                }
            };
        }
    </script>
</body>
</html>

