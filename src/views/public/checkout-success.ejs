<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/output.css?v=2">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; }
        html { scroll-behavior: smooth; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .dark ::-webkit-scrollbar-thumb { background: #334155; }
        .toast-container { position: fixed; top: 80px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
        .toast { padding: 12px 20px; border-radius: 12px; font-size: 14px; font-weight: 600; color: white; box-shadow: 0 10px 40px -10px rgba(0,0,0,0.3); transform: translateX(120%); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1); max-width: 360px; }
        .toast.show { transform: translateX(0); }
        .toast-success { background: #10b981; }
        .toast-error { background: #ef4444; }
        .toast-info { background: #3b82f6; }

        @keyframes greenGlowPulse {
            0%, 100% { opacity: 0.2; transform: scale(1); }
            50% { opacity: 0.4; transform: scale(1.04); }
        }
        .green-glow {
            animation: greenGlowPulse 3s ease-in-out infinite;
        }

        /* Animated checkmark - SVG draw-in */
        @keyframes drawCheck {
            0% { stroke-dashoffset: 48; }
            100% { stroke-dashoffset: 0; }
        }
        @keyframes scaleIn {
            0% { transform: scale(0); opacity: 0; }
            60% { transform: scale(1.1); }
            100% { transform: scale(1); opacity: 1; }
        }
        .checkmark-circle {
            animation: scaleIn 0.4s cubic-bezier(0.4,0,0.2,1) forwards;
        }
        .checkmark-path {
            stroke-dasharray: 48;
            stroke-dashoffset: 48;
            animation: drawCheck 0.5s 0.3s cubic-bezier(0.4,0,0.2,1) forwards;
        }

        /* Staggered item animation */
        @keyframes slideInItem {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .stagger-item {
            opacity: 0;
            animation: slideInItem 0.4s ease-out forwards;
        }
        .stagger-item:nth-child(1) { animation-delay: 0.6s; }
        .stagger-item:nth-child(2) { animation-delay: 0.75s; }
        .stagger-item:nth-child(3) { animation-delay: 0.9s; }
        .stagger-item:nth-child(4) { animation-delay: 1.05s; }
        .stagger-item:nth-child(5) { animation-delay: 1.2s; }
    </style>
    <script>
        window.uiCore = {
            toggleTheme: function () {
                document.documentElement.classList.toggle('dark');
                localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
            },
            showToast: function(message, type = 'info') {
                const container = document.getElementById('toast-container') || (() => {
                    const c = document.createElement('div');
                    c.id = 'toast-container';
                    c.className = 'toast-container';
                    document.body.appendChild(c);
                    return c;
                })();
                const toast = document.createElement('div');
                toast.className = 'toast toast-' + type;
                toast.textContent = message;
                container.appendChild(toast);
                requestAnimationFrame(() => { requestAnimationFrame(() => { toast.classList.add('show'); }); });
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 400);
                }, 4000);
            }
        };
        if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>
</head>

<body class="bg-[#F4F7FA] dark:bg-[#09090B] text-slate-800 dark:text-slate-200 antialiased flex items-center justify-center min-h-screen p-4" x-data="{ copiedUser: false, copiedPass: false }">

    <!-- Simple Navbar -->
    <nav class="fixed top-0 z-50 w-full h-16 bg-white/70 dark:bg-[#09090B]/70 backdrop-blur-xl border-b border-slate-200/80 dark:border-slate-800/80 flex items-center justify-between px-4 lg:px-6 transition-colors duration-300">
        <a href="/dashboard" class="flex items-center gap-3 group">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white shadow-lg shadow-blue-600/20 group-hover:shadow-blue-600/40 group-hover:scale-110 transition-all duration-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <span class="text-lg font-black tracking-tight text-slate-900 dark:text-white">Dashboard</span>
        </a>
        <button onclick="window.uiCore.toggleTheme()" class="p-2.5 text-slate-500 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800 rounded-xl transition-all active:scale-90 hover:rotate-12 duration-200">
            <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
        </button>
    </nav>

    <!-- Success Card -->
    <div class="max-w-lg w-full relative" style="margin-top: 2rem;">
        <!-- Green gradient glow behind card -->
        <div class="absolute inset-0 bg-gradient-to-br from-green-500/20 via-emerald-600/10 to-transparent rounded-3xl blur-2xl green-glow pointer-events-none"></div>

        <div data-aos="zoom-in" class="relative bg-white dark:bg-[#12121A] rounded-3xl p-8 sm:p-10 border border-green-200 dark:border-green-500/20 shadow-xl text-center hover:shadow-2xl transition-shadow duration-300">

            <!-- Animated Checkmark -->
            <div class="checkmark-circle w-20 h-20 bg-green-50 dark:bg-green-500/15 text-green-600 dark:text-green-400 rounded-full flex items-center justify-center mx-auto mb-8 shadow-lg shadow-green-100 dark:shadow-green-500/10">
                <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path class="checkmark-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>

            <h1 class="text-3xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Order Successful!</h1>
            <p class="text-slate-500 dark:text-slate-400 mb-8 font-medium">Order ID: <span class="font-mono text-blue-600 dark:text-blue-400 font-bold"><%= order.orderId %></span></p>

            <!-- Delivery Details -->
            <div class="bg-slate-50 dark:bg-slate-900/50 rounded-2xl p-6 text-left mb-8 border border-slate-100 dark:border-slate-800">
                <h3 class="font-black text-slate-400 dark:text-slate-500 uppercase text-[10px] tracking-widest mb-4">Delivery Details</h3>
                <div class="space-y-4">
                    <div class="stagger-item flex justify-between items-center pb-3 border-b border-slate-200 dark:border-slate-800">
                        <span class="text-slate-500 dark:text-slate-400 text-sm">Product</span>
                        <span class="font-black text-slate-900 dark:text-white"><%= order.productNameSnap %></span>
                    </div>
                    <% if (order.data.serverUsername) { %>
                        <div class="stagger-item flex justify-between items-center pb-3 border-b border-slate-200 dark:border-slate-800 gap-2">
                            <span class="text-slate-500 dark:text-slate-400 text-sm flex-shrink-0">Panel Username</span>
                            <div class="flex items-center gap-1.5">
                                <span class="font-mono font-bold text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-500/15 px-2 py-0.5 rounded-lg text-sm" id="usernameField"><%= order.data.serverUsername %></span>
                                <button @click="navigator.clipboard.writeText(document.getElementById('usernameField').innerText); copiedUser = true; window.uiCore.showToast('Username copied!', 'success'); setTimeout(() => copiedUser = false, 2000)" class="p-1 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-200 active:scale-90">
                                    <span x-show="!copiedUser">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                                    </span>
                                    <span x-show="copiedUser" x-transition>
                                        <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                                    </span>
                                </button>
                            </div>
                        </div>
                        <div class="stagger-item flex justify-between items-center gap-2">
                            <span class="text-slate-500 dark:text-slate-400 text-sm flex-shrink-0">Panel Password</span>
                            <div class="flex items-center gap-1.5">
                                <span class="font-mono font-bold text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-500/15 px-2 py-0.5 rounded-lg text-sm" id="passwordField"><%= order.data.serverPassword %></span>
                                <button @click="navigator.clipboard.writeText(document.getElementById('passwordField').innerText); copiedPass = true; window.uiCore.showToast('Password copied!', 'success'); setTimeout(() => copiedPass = false, 2000)" class="p-1 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-400 hover:text-green-600 dark:hover:text-green-400 transition-all duration-200 active:scale-90">
                                    <span x-show="!copiedPass">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                                    </span>
                                    <span x-show="copiedPass" x-transition>
                                        <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                                    </span>
                                </button>
                            </div>
                        </div>
                    <% } %>
                    <% if (order.data.downloadUrl) { %>
                        <div class="stagger-item space-y-3 pt-2">
                            <span class="text-slate-500 dark:text-slate-400 text-sm block mb-1">Download Link</span>
                            <a href="<%= order.data.downloadUrl %>" target="_blank" class="group block w-full py-3.5 px-4 bg-blue-600 hover:bg-blue-500 text-white text-center rounded-xl font-black transition-all duration-300 shadow-lg shadow-blue-600/20 hover:shadow-blue-500/40 hover:-translate-y-0.5 active:scale-[0.97]">
                                Download Now
                                <span class="inline-block ml-1 group-hover:translate-y-0.5 transition-transform duration-200">&darr;</span>
                            </a>
                            <% if (order.data.instructions) { %>
                                <div class="stagger-item mt-4 p-4 bg-white dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700 text-sm text-slate-600 dark:text-slate-400 italic leading-relaxed">
                                    <span class="font-bold not-italic block mb-1 text-slate-900 dark:text-white">Instructions:</span>
                                    <%= order.data.instructions %>
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="space-y-3">
                <a href="/dashboard" class="group block w-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-black py-4 px-4 rounded-2xl transition-all duration-300 shadow-xl shadow-slate-900/10 dark:shadow-white/10 hover:-translate-y-0.5 hover:shadow-xl active:scale-[0.97] text-center">
                    <span class="inline-flex items-center gap-2">
                        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        Go to Dashboard
                    </span>
                </a>
                <a href="/" class="block w-full text-slate-500 dark:text-slate-400 font-bold py-2 text-sm hover:text-slate-900 dark:hover:text-white transition-colors duration-200">Return Home</a>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 600, easing: 'ease-out-cubic', once: true, offset: 40 });
    </script>
</body>

</html>

