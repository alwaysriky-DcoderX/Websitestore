                    <!-- SMM Panel (Wide) -->
                    <div class="bento-wide group relative overflow-hidden rounded-[2rem] glass-panel p-8 flex flex-col justify-between hover:-translate-y-2 hover:shadow-2xl hover:shadow-orange-500/20 transition-all duration-500 border border-slate-200 dark:border-white/5" data-aos="fade-up" data-aos-delay="100">
