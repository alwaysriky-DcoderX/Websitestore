# Server Configuration
PORT=3000
NODE_ENV=development
SESSION_SECRET=your_super_secret_session_key_here

# Database Configuration (PostgreSQL)
# Ganti dengan URL database PostgreSQL Anda
DATABASE_URL="postgresql://username:password@localhost:5432/auto_order_db?schema=public"

# Catatan:
# Mulai versi ini, API Keys (seperti Pakasir, SMSCode, RumahOTP, dan SMM MedanPedia)
# TIDAK LAGI disimpan di file .env.
# Silakan login sebagai Admin di website, lalu pergi ke menu "Settings"
# untuk memasukkan dan mengelola semua API Key tersebut langsung dari panel Admin.
